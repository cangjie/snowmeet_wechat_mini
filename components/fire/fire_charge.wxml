<view wx:if="{{order.id == 0}}" >
  <view class="view-row" >
    <view wx:if="{{order.type == '租赁'}}" class="left-column" >【押金金额】</view>
    <view wx:else class="left-column" >【收款金额】</view>
    <view class="right-column" >
      <input class="input" style="width: 150rpx;text-align: center;" type="digit" bindinput="setAmount" />
    </view>
  </view>
  <view class="view-row" >
    <view class="left-column" >【订单备注】</view>
    <view class="right-column" >
      <textarea style="width: 450rpx;height: 200rpx;" class="input" bindinput="setMemo" ></textarea>
    </view>
  </view>
  <view class="view-row" style="justify-content: center;margin-top: 50rpx;" >
    <van-button type="primary" bind:click="placeOrder" disabled="{{!order.paying_amount}}" > 确 认 收 款 </van-button>
  </view>
</view>
<payment wx:else orderId="{{order.id}}" bindOrderPaidResult="dealPaidResult" ></payment>