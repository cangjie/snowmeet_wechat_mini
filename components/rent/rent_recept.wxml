<scroll-view scroll-y style="height: 100%;">
  <fui-swipeaction-group>
    <van-collapse value="{{rentalActiveIndex}}" bind:change="onRentalCollapseChange">
      <fui-swipe-action wx:for="{{rentals}}" wx:for-item="rental" wx:key="timeStamp" bind:click="del" id="{{index}}">

        <van-collapse-item name="{{index}}">

          <view slot="title"
            style="background-color: var(--rental-title-backgroud-color); margin-top: 0rpx;color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})">
            <view class="view-row"
              style="background-color: var(--rental-title-backgroud-color);margin-top: 0rpx;color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})">
              <view class="left-column" style="width: var(--title-width);">
                {{rental.rentItems.length > 1 ? (rental.rentItems.length) : ''}}【{{rental.package_id?'套餐':'单品'}}】
              </view>
              <view style="width: 400rpx;font-size: var(--standart-font-size);">
                {{rental.package_id? rental.name : rental.rentItems[0].category.name}}</view>
              <view class="view-row" style="width: 100rpx;margin-top: 0rpx;">
                <block wx:if="{{rental.package_id}}">
                  <!--重选套餐按钮-->
                </block>
                <block wx:else>
                  <block wx:if="{{rental.rentItems[0].noCode}}">
                    <van-button wx:if="{{rental.rentItems[0].name && rental.rentItems[0].name != ''}}" type="primary"
                      round size="mini" id="{{rental.rentItems[0].itemIndex}}" bind:click="selectCategory">重选
                    </van-button>
                    <van-button wx:else type="primary" round size="mini" id="{{rental.rentItems[0].itemIndex}}"
                      bind:click="selectCategory">选择</van-button>
                  </block>
                </block>
              </view>
            </view>
            <view class="view-row">
              <view class="left-column" style="width: var(--title-width);">
                {{rental.rentItems.length > 1 ? ((rental.neededRentItemCount) ? rental.neededRentItemCount : rental.rentItems.length): ''}}【押金】
              </view>
              <view class="right-column view-row" style="width:calc(var(--total-width) / 2 -  var(--title-width))">
                <input class="input"
                  style="text-align: center;width:140rpx;color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})"
                  type="digit" placeholder="{{rental.realGuaranty}}" id="{{index}}" bindinput="setGuaranty"
                  bindblur="updateGuaranty" />{{rental.guaranty_discount>0?'减':''}}
              </view>
              <view class="left-column" style="width: var(--title-width);">【租金】</view>
              <view class="right-column" style="width:calc(var(--total-width) / 2 -  var(--title-width))">
                <input class="input"
                  style="text-align: center; width: 100rpx;color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})"
                  type="digit" placeholder="{{rental.pricePresets[0].price}}" id="{{index}}" bindinput="setPrice"
                  bindblur="updatePrice" />
              </view>
            </view>
            <view style="font-family: 'icon-font';">
              双 双鞋 杖
            </view>
          </view>

          <view
            style="background-color: var(--rental-title-backgroud-color);color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})">
            <view class="view-row" style="margin-top: 0rpx;">
              <view class="left-column" style="width: var(--title-width);">【起租日期】</view>
              <view class="right-column" style="width:calc(var(--total-width) / 2 -  var(--title-width))">
                {{rental.startDateStr}}
              </view>
              <view class="left-column" style="width: var(--title-width);">【起租时间】</view>
              <view class="right-column" style="width:calc(var(--total-width) / 2 -  var(--title-width))">
                {{rental.startTimeStr}}
              </view>
            </view>
            <view class="view-row"
              style="color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})">
              <view class="left-column" style="width: var(--title-width);">【备注】</view>
              <view class="right-column">
                <input class="input"
                  style="width:500rpx;color:var({{rental.wellFormed == true? '--rental-title-well-color': '--rental-title-unwell-color'}})"
                  id="{{index}}" bindinput="setRentalMemo" />
              </view>
            </view>
            <view class="view-row" style="height: 60rpx; justify-content: center;margin-top: 20rpx;">
              <van-button plain size="small" type="primary" bind:click="showItem" id="{{index}}">
                设置押金租金
              </van-button>
              <van-button plain size="small" type="info" id="{{index}}" bind:click="showPriceList"
                style="margin-left: 20rpx" disabled="{{rental.rentItems[0].category_id == null}}"> 查 看 价 目 表
              </van-button>
            </view>
            <view class="view-row"
              style="height: 60rpx; justify-content: center;margin-top: 20rpx;margin-bottom: 20rpx;">

              <van-button wx:if="{{rental.mixedPickType == true}}" size="small" type="danger"
                style="margin-right: 20rpx;">混合发放</van-button>

              <block wx:if="{{rental.pick_type == null}}">
                <van-button size="small" type="warning" plain style="margin-right: 20rpx;"
                  bind:click="setRentalPickType" id="{{index}}_0">立即租赁</van-button>
                <van-button size="small" type="warning" plain style="margin-right: 20rpx;"
                  bind:click="setRentalPickType" id="{{index}}_1">先租后取</van-button>
                <van-button size="small" type="warning" plain style="margin-right: 0rpx;" bind:click="setRentalPickType"
                  id="{{index}}_2">延时租赁</van-button>
              </block>
              <block wx:else>
                <van-button size="small" type="warning">{{rental.pick_type}}</van-button>
                <van-button size="small" type="primary" style="margin-left: 20rpx;" bind:click="resetPickType"
                  id="{{index}}"> 重 选 </van-button>
              </block>
            </view>
            <van-collapse id="{{index}}" value="{{rentalActiveIndex}}" bind:change="onItemCollapseChange">
              <view
                style="padding-left: calc((var(--total-width) - var(--total-width-sub))/2); padding-right:calc((var(--total-width) - var(--total-width-sub))/2);padding-bottom: 20rpx;background-color: var(--rental-title-backgroud-color);">
                <van-collapse-item wx:for="{{rental.rentItems}}" wx:for-index="itemIndex"
                  name="{{index}}_{{itemIndex}}">
                  <view slot="title" class="view-row"
                    style="background-color: var({{item.noNeed == true? '--no-use-background-color' : (item.wellFormed? '--rent-item-well-background-color': '--rent-item-unwell-background-color')}});">
                    <view class="left-column" style="width:var(--title-width-sub)">【品类】</view>
                    <view class="right-column" style="width:calc(var(--total-width-sub) - var(--title-width-sub))">
                      <block wx:if="{{item.canChooseCategory==true}}">
                        <picker id="{{index}}_{{itemIndex}}" range="{{item.chooseCategories}}" range-key="name"
                          class="input" bindchange="selectRentItemCategory">
                          <picker-view>{{item.category.name}}</picker-view>
                        </picker>
                      </block>
                      <block wx:else>
                        {{item.category.name}}
                      </block>
                    </view>
                  </view>
                  <view
                    style="color: #000000;background-color: var({{item.noNeed == true? '--no-use-background-color' : (item.wellFormed? '--rent-item-well-background-color': '--rent-item-unwell-background-color')}});">
                    <view class="view-row" style="margin-top: 0rpx;">
                      <view class="left-column" style="width:var(--title-width-sub)">【编码】</view>
                      <view class="right-column view-row"
                        style="width:calc(var(--total-width-sub) - var(--title-width-sub))">
                        <input class="input" style="width:200rpx"
                          disabled="{{item.noCode != false || item.noNeed == true}}" bindtap="searchCodePop"
                          id="{{index}}_{{itemIndex}}" value="{{item.code}}" />
                        <van-icon name="scan" size="19px" disabled="{{item.noNeed}}" />
                        <van-button id="{{index}}_{{itemIndex}}" wx:if="{{item.noCode == true}}"
                          style="margin-left:30rpx" size="mini" type="info" bind:click="setNoCode">无编码</van-button>
                        <van-button id="{{index}}_{{itemIndex}}" wx:else style="margin-left:30rpx" size="mini"
                          type="info" plain bind:click="setNoCode">无编码</van-button>
                        <block wx:if="{{rental.rentItems.length > 1}}">
                          <van-button id="{{index}}_{{itemIndex}}" wx:if="{{item.noNeed == true}}"
                            style="margin-left:30rpx" size="mini" type="danger" bind:click="setNoNeed">不需要</van-button>
                          <van-button id="{{index}}_{{itemIndex}}" wx:else style="margin-left:30rpx" size="mini"
                            type="danger" plain bind:click="setNoNeed">不需要</van-button>
                        </block>
                      </view>
                    </view>
                    <view class="view-row">
                      <view class="left-column" style="width:var(--title-width-sub)">【名称】</view>
                      <view class="right-column" style="width:calc(var(--total-width-sub) - var(--title-width-sub))">
                        <input class="input"
                          style="width: calc((var(--total-width-sub) - var(--title-width-sub)) * 0.8);"
                          bindinput="setItemValue" id="{{index}}_{{itemIndex}}_name"
                          disabled="{{item.noCode == false || item.noNeed == true }}" value="{{item.name}}" />
                      </view>
                    </view>
                    <view class="view-row">
                      <view class="left-column" style="width:var(--title-width-sub)">【备注】</view>
                      <view class="right-column" style="width:calc(var(--total-width-sub) - var(--title-width-sub))">
                        <input class="input" disabled="{{item.noNeed == true}}" bindinput="setItemValue"
                          id="{{index}}_{{itemIndex}}_memo"
                          style="width: calc((var(--total-width-sub) - var(--title-width-sub)) * 0.8);" />
                      </view>
                    </view>
                    <view class="view-row" style="margin-top: 20rpx;justify-content: center;">
                      <block wx:if="{{item.pick_type == null}}">
                        <van-button size="small" plain type="primary" id="{{index}}_{{itemIndex}}_0"
                          bind:click="setRentItemPickType">立即租赁</van-button>
                        <van-button size="small" plain type="primary" style="margin-left: 50rpx;"
                          id="{{index}}_{{itemIndex}}_1" bind:click="setRentItemPickType">先租后取</van-button>
                      </block>
                      <block wx:else>
                        <van-button size="small" type="primary">{{item.pick_type}}</van-button>
                        <van-button size="small" type="primary" style="margin-left:20rpx"
                          bind:click="resetRentItemPickType" id="{{index}}_{{itemIndex}}"> 重 选 </van-button>
                      </block>
                    </view>

                  </view>
                </van-collapse-item>
              </view>
            </van-collapse>
          </view>
        </van-collapse-item>
        <view style="height:50rpx"></view>
      </fui-swipe-action>
    </van-collapse>
  </fui-swipeaction-group>
  <view style="height:300rpx"></view>
  <van-divider contentPosition="center" textColor="#1989fa">新增租赁商品</van-divider>
  <view class="view-row" style="justify-content: center;">
    <van-button type="primary" bind:click="addNewPackage">添加套餐</van-button>
    <van-button style="margin-left: 10rpx;" type="info" disabled>扫描条码</van-button>
    <van-button style="margin-left: 10rpx;" type="warning" bind:click="searchBarcodeFuzzy">搜索单品</van-button>
    <van-button style="margin-left: 10rpx;" type="danger" bind:click="addNewBlank">无码物品</van-button>
  </view>
</scroll-view>
<van-popup show="{{ showPopUp }}">
  <package_selector wx:if="{{popUpContent == 'packageSelector'}}" shop="{{shop}}" bindConfirm="selectPackageConfirm"
    bindCancel="cancelPopUp"></package_selector>
  <search-product-fuzzy wx:if="{{popUpContent == 'searchBarCodeFuzzy'}}" categoryId="{{searchCategoryId}}"
    bindCancel="cancelPopUp" barCode="{{searchBarCode}}" bindConfirm="confirmProduct"></search-product-fuzzy>
  <category-selector wx:if="{{popUpContent == 'categorySelector'}}" bindCancel="cancelPopUp"
    bindConfirm="confirmCategory">
  </category-selector>
</van-popup>
<fui-backdrop show="{{showBackdrop}}" closable>
  <scroll-view style="height: 90vh;margin-left: auto;margin-right: auto;" scroll-y>
    <block wx:if="{{action == 'package'}}">
      <fui-card title="套餐名称：{{currentRental.name}}" tag="共{{currentRental.rentItems.length}}件">
        <view class="fui-card__content" style="width: 650rpx; margin-top:50rpx;height: {{windowHeight}}rpx">
          <scroll-view scroll-y="true" style="height: {{windowHeight }}rpx">
            <rent_charge rentItem="{{currentRental}}" bindRentalUpdated="onRentalChange" shop="{{shopObj}}">
            </rent_charge>
          </scroll-view>
        </view>
        <view class="view-row" style="margin-top: 50rpx;margin-bottom: 50rpx;">
          <button class="input" size="mini" bindtap="cancelBackdrop"> 取 消 </button>
          <button class="input" size="mini" bindtap="saveUpdatedRental"> 保 存 </button>
        </view>
      </fui-card>
    </block>
    <block wx:if="{{action == 'item'}}">
      <view style="background-color: white;width:650rpx;margin-left: auto;margin-right: auto;">
        <view style="height: 10rpx;"></view>
        <view class="view-row">
          <view class="left-column" style="width: 150rpx;">【品类】</view>
          <view class="right-column" style="width: 500rpx;">
            {{currentRental.rentItems[0].category.name}}
          </view>
        </view>
        <view class="view-row">
          <view class="left-column" style="width: 150rpx;">【编码】</view>
          <view class="right-column view-row" style="width: 500rpx;">
            {{currentRental.rentItems[0].noCode? '【无】' : currentRental.rentItems[0].code}}
          </view>
        </view>
        <view class="view-row">
          <view class="left-column" style="width: 150rpx;">【名称】</view>
          <view class="right-column" style="width: 500rpx;">
            {{currentRental.rentItems[0].name? currentRental.rentItems[0].name: ''}}
          </view>
        </view>
        <view style="height: 20rpx;"></view>
        <rent_charge rentItem="{{currentRental}}" bindRentalUpdated="onRentalChange" shop="{{shopObj}}"></rent_charge>
        <view class="view-row" style="margin-top: 50rpx;margin-bottom: 50rpx;">
          <button class="input" size="mini" bindtap="cancelBackdrop"> 取 消 </button>
          <button class="input" size="mini" bindtap="saveUpdatedRental"> 保 存 </button>
        </view>
        <view style="height: 50rpx;"></view>
      </view>
    </block>
    <block wx:if="{{action == 'priceList'}}">
      <rent-price-list shopName="{{shop}}" type="{{type}}" dayType="{{dayType}}" targetId="{{targetId}}"
        memberId="{{memberId}}"></rent-price-list>
      <view class="view-row" style="width: 90%;background-color: white;margin-left: auto;margin-right: auto;">
        <button class="input" size="mini" bindtap="cancelBackdrop" style="margin-top:50rpx;margin-bottom: 50rpx;"> 关 闭
        </button>
      </view>
    </block>
  </scroll-view>
</fui-backdrop>
<van-calendar id="{{calenderId}}" show="{{ showCalendar }}" bind:close="onCloseCalendar"
  bind:confirm="onConfirmCalendar" />