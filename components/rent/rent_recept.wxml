<scroll-view scroll-y style="height: 100%;" >
  <!--view style="background-color:gray; height: 300rpx;">aaa</view>
  <view style="height: 300rpx;">bbb</view>
  <view style="background-color:gray; height: 300rpx;">ccc</view>
  <view style="height: 300rpx;">ddd</view>
  <view style="background-color:gray; height: 300rpx;">eee</view-->
    <fui-swipeaction-group>
      <fui-swipe-action wx:for="{{rentals}}" wx:for-item="rental" bind:click="del" id="{{index}}">
        <view style="height: 50rpx;"></view>
        <view wx:if="{{rental.package_id == null || rental.package_id == undefined}}" class="view-row">
          <view class="number-label" style="margin-top: 100rpx;font-size: 9pt;">【{{rental.rentItems[0].itemIndex}}】</view>
          <view style="width: 650rpx; background-color: #FFF0F0;">
            <view class="view-row">
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;"  >【编码】</view>
              <view class="right-column view-row" style="width: 240rpx;">
                <input bind:tap="searchListBarcodeFuzzy" class="input" style="width: 175rpx;text-align: center;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}" value="{{rental.rentItems[0].noCode? '无' : (rental.rentItems[0].code?rental.rentItems[0].code:'')}}" disabled="{{rental.rentItems[0].noCode}}" id="{{rental.rentItems[0].itemIndex}}" />
                <van-icon name="scan" size="19px" />
                <!--input class="input" style="width: 145rpx;" value="{{rental.rentItems[0].code==null?'':rental.rentItems[0].code}}" /-->

                <!--van-icon name="scan" size="19px" /-->

              </view>
              <view class="left-column" style="width: 140rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【无编码】</view>
              <view class="right-column" style="width: 75rpx;" >
                <checkbox-group id="{{rental.rentItems[0].itemIndex}}" bindchange="setNoCode">
                  <checkbox checked="{{rental.rentItems[0].noCode}}" value="1"></checkbox>
                </checkbox-group>
              </view>
            </view>
            <view class="view-row">
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;" >【品类】</view>
              <view class="right-column right-column1 view-row" wx:if="{{rental.rentItems[0].category}}" style="width: 475rpx;" >
                <view style="width: 350rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}" >
                  {{rental.rentItems[0].category.name}}
                </view>
                <view>
                  <van-button wx:if="{{rental.rentItems[0].noCode}}" type="primary" round size="mini" bind:click="searchListBarcodeFuzzy" id="{{rental.rentItems[0].itemIndex}}" bind:click="selectCategory">重选</van-button>
                </view>
              </view>
              <view class="right-column right-column1" wx:else style="width: 475rpx;" >
                <van-button wx:if="{{rental.rentItems[0].noCode}}" type="primary" round size="mini" bind:click="searchListBarcodeFuzzy" id="{{rental.rentItems[0].itemIndex}}" bind:click="selectCategory">选择</van-button>
              </view>
            </view>
            <view class="view-row">
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;"  >【名称】</view>
              <view class="right-column right-column1" wx:if="{{rental.rentItems[0].noCode}}">
                <input class="input" style="width: 450rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}" 
                value="{{rental.rentItems[0].name == null? '' : rental.rentItems[0].name}}" 
                id="{{rental.rentItems[0].itemIndex}}" bindinput="setItemName" />
              </view>
              <view class="right-column right-column1" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 500rpx"  wx:else>{{rental.rentItems[0].name}}</view>
            </view>
            <view class="view-row">
              <view class="left-column"></view>
              <view class="right-column"></view>
            </view>
            <view class="view-row" style="margin-bottom: 20rpx;">
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;"  >【押金】</view>
              <view class="right-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 240rpx;"  >{{rental.realDepositStr}}</view>
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 140rpx;"  >【租金】</view>
              <view class="right-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}; width:130rpx"  >¥100.00起</view>
              <!--租金显示相关的周末价、平日价、节假日价-->
            </view>
            <view class="view-row" style="margin-bottom: 20rpx;">
              <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;" >【免押金】</view>
              <view class="right-column " >
                <checkbox-group>
                  <checkbox></checkbox>
                </checkbox-group>
              </view>
              <view class="left-column"></view>
              <view class="right-column"></view>
            </view>
            <view class="view-row" style="margin-bottom: 20rpx;">
              <view class="left-column"  style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;" >【起租日】</view>
              <view class="right-column ">
                <picker mode="date" class="input">
                  <picker-view  style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}"  >{{startDate}}</picker-view>
                </picker>
              </view>
              <view class="left-column"></view>
              <view class="right-column"></view>
            </view>
            <view class="view-row" style="margin-bottom: 20rpx;">
              <view class="left-column" style="width: 170rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}};width: 170rpx;">【立即发放】
              </view>
              <view class="right-column" style="margin-left: 0rpx;" >
                <checkbox-group>
                  <checkbox></checkbox>
                </checkbox-group>
              </view>
            </view>
            <view class="view-row" style="justify-content: center; margin-bottom: 10rpx;">
              <van-button plain type="primary" disabled="{{rental.rentItems[0].category_id == null}}" bind:click="showItem" id="{{index}}">
                设置 押金 租金 起租时间等
              </van-button>
            </view>
          </view>
        </view>
        <block wx:else>
          <view class="view-row">
            <view class="number-label"></view>
            <view style="width: 650rpx;background-color: #F0FFF0;">
              <view class="view-row">
                <view class="left-column">【套餐】</view>
                <view class="right-column right-column1">{{rental.name}}</view>
              </view>
              <view class="view-row" style="margin-bottom: 20rpx;">
                <view class="left-column">【押金】</view>
                <view class="right-column" style="width: 260rpx;">{{rental.realDepositStr}}</view>
                <view class="left-column">【租金】</view>
                <view class="right-column" style=" width:150rpx">¥100.00起</view>
              </view>
              <view class="view-row" style="margin-bottom: 20rpx;">
                <view class="left-column">【免押金】</view>
                <view class="right-column">
                  <checkbox-group>
                    <checkbox></checkbox>
                  </checkbox-group>
                </view>
                <view class="left-column"></view>
                <view class="right-column"></view>
              </view>
              <view class="view-row" style="margin-bottom: 20rpx;">
                <view class="left-column">【起租日】</view>
                <view class="right-column ">
                  <picker mode="date" class="input">
                    <picker-view>{{startDate}}</picker-view>
                  </picker>
                </view>
                <view class="left-column"></view>
                <view class="right-column"></view>
              </view>
              <view class="view-row" style="justify-content: center; margin-bottom: 10rpx;">
                <van-button plain type="primary" bind:click="showPackage" id="{{index}}">设置 押金 租金 起租时间等 </van-button>
              </view>
            </view>
          </view>
          <block wx:for="{{rental.rentItems}}">
            <view class="view-row">
              <view class="number-label" style="margin-top: 50rpx;font-size: 9pt;">
                【{{item.itemIndex}}】
              </view>
              <view style="display:flex;justify-content: center; width: 650rpx; background-color: #F0FFF0;" id="{{item.itemIndex}}">
                <view style="width: 630rpx; background-color: #FFF0FF">
                  <view class="view-row" style="margin-bottom: 20rpx;">
                    <view class="left-column" style="width:140rpx; color:{{item.textColor?item.textColor:defaultTextColor}}">【编码】</view>
                    <view class="right-column view-row" style="width:240rpx;color:{{item.textColor?item.textColor:defaultTextColor}};">
                      <input bind:tap="searchListBarcodeFuzzy" class="input" style="width: 175rpx;text-align: center;" value="{{item.noCode? '无' : (item.code?item.code:'')}}" disabled="{{item.noCode}}" id="{{item.itemIndex}}" />
                      <van-icon name="scan" size="19px" />
                    </view>
                    <view class="left-column" style="width: 160rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【无编码】</view>
                    <view class="right-column" style="width: 75rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">
                      <checkbox-group id="index" id="{{item.itemIndex}}" bindchange="setNoCode">
                        <checkbox checked="{{item.noCode}}" value="1"></checkbox>
                      </checkbox-group>
                    </view>
                  </view>
                  <view class="view-row">
                    <view class="left-column" style="width:140rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【品类】</view>
                    <view class="right-column right-column1" style="width:475rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">{{item.categoryName}}</view>
                  </view>
                  <view class="view-row">
                    <view class="left-column" style="width:140rpx; color:{{item.textColor?item.textColor:defaultTextColor}}">【名称】</view>
                    <view class="right-column right-column1" style="width: 475rpx;" wx:if="{{item.noCode}}">
                      <input class="input" style="width: 450rpx;" bindinput="setItemName" id="{{item.itemIndex}}"
                      value="{{item.name == null? '' : item.name}}" />
                    </view>
                    <view class="right-column right-column1" wx:else>{{item.name == null? '' : item.name}}</view>
                  </view>
                  <view class="view-row" style="margin-bottom:20rpx">
                    <view class="left-column" style="width:140rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【不需要】</view>
                    <view class="right-column" style="width:240rpx;color:{{item.textColor?item.textColor:defaultTextColor}};width: 240rpx;">
                      <checkbox-group>
                        <checkbox></checkbox>
                      </checkbox-group>
                    </view>
                    <view class="left-column" style="width: 160rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【立即发放】
                    </view>
                    <view class="right-column" style="width: 50rpx;margin-left: 0rpx;">
                      <checkbox-group>
                        <checkbox></checkbox>
                      </checkbox-group>
                    </view>
                  </view>
                  <view style="width: 630rpx;background-color: #F0FFF0;height: 10rpx;"></view>
                </view>
              </view>
            </view>
          </block>
        </block>
      </fui-swipe-action>
    </fui-swipeaction-group>
  <van-divider contentPosition="center" textColor="#1989fa">新增租赁商品</van-divider>
  <view class="view-row" style="justify-content: center;" >
    <van-button  type="primary" bind:click="addNewPackage" >添加套餐</van-button>
    <van-button  style="margin-left: 10rpx;" type="info" disabled >扫描条码</van-button>
    <van-button  style="margin-left: 10rpx;" type="warning" bind:click="searchBarcodeFuzzy" >搜索单品</van-button>
    <van-button  style="margin-left: 10rpx;" type="danger"  bind:click="addNewBlank" >无码物品</van-button>
  </view>
</scroll-view>
<van-popup show="{{ showPopUp }}" >
  <package_selector wx:if="{{popUpContent == 'packageSelector'}}" bindConfirm="selectPackageConfirm" bindCancel="cancelPopUp"></package_selector>
  <search-product-fuzzy wx:if="{{popUpContent == 'searchBarCodeFuzzy'}}" categoryId="{{searchCategoryId}}" bindCancel="cancelPopUp" barCode="{{searchBarCode}}" bindConfirm="confirmProduct"></search-product-fuzzy>
  <category-selector wx:if="{{popUpContent == 'categorySelector'}}" bindCancel="cancelPopUp" bindConfirm="confirmCategory">
  </category-selector>
</van-popup>