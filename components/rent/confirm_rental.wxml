<view style="background-color: white">
  <view class="view-row" style="justify-content: center;width: 700rpx;text-align: center;">租金明细</view>
  <view style="height:20rpx" ></view>
  <scroll-view scroll-y style="width: 700rpx;height:700rpx;">
    <block wx:for="{{rental.details}}" >
      <view class="view-row">
        <view class="left-column">【日期】</view>
        <view class="right-column">{{item.dateStr}}</view>
        <view class="left-column">【周末】</view>
        <view class="right-column">{{item.day_type}}</view>
      </view>
      <view class="view-row">
        <view class="left-column">【场次】</view>
        <view class="right-column">{{item.rent_type}}</view>
        <view class="left-column">【类型】</view>
        <view class="right-column">{{item.scene}}</view>
      </view>
      <view class="view-row">
        <view class="left-column">【价格】</view>
        <view class="right-column">{{item.amountStr}}</view>
        <view class="left-column">【减免】</view>
        <view class="right-column">
          <input id="{{item.id}}" class="input" style="width: 75rpx;text-align: center;" 
            value="{{item.discountTotalAmount}}" bindinput="setDiscount" />
        </view>
      </view>
      <view class="view-row">
        <view class="left-column">【小计】</view>
        <view class="right-column">{{item.summaryStr}}</view>
        <view class="left-column">【取消】</view>
        <view class="right-column">
          <checkbox-group id="{{item.id}}" bindchange="setValid" >
            <checkbox checked="{{item.valid == 0}}" ></checkbox>
          </checkbox-group>
        </view>
      </view>
      <!--view class="view-row">
        <view class="left-column">【备注】</view>
        <view class="right-column">
          <input class="input" 
        </view>
        
      </view-->
      <van-divider></van-divider>
    </block>
