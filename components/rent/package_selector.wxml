<fui-card title="选择套餐" full tag="总计：{{packages.length}}" >
  <view  style="width: 700rpx;">
    <radio-group bindchange="selectPackage" >
      <scroll-view scroll-y >
      <view class="view-row" wx:for="{{packages}}" style="width: 700rpx;" >
        <view class="left-column" >
          <radio value="{{item.id}}" ></radio>
        </view>
        <view class="right-column" style="margin-left: 50rpx" >{{item.name}}</view>
      </view>
    </scroll-view>
    </radio-group>
  </view>
  <view class="view-row" style="margin-top: 50rpx;justify-content: center;margin-bottom: 50rpx;" >
    <view>
      <van-button round type="primary" bind:click="confirm" > 确 认 </van-button>
    </view>
    <view style="width:200rpx" ></view>
    <view>
      <van-button round type="warning" bind:click="close" > 取 消 </van-button>
    </view>
  </view>
</fui-card>