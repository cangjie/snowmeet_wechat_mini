<view style="width: 650rpx;margin-left: 0rpx; margin-right: 0rpx;">
  <van-collapse value="{{ activeNames }}" bind:change="onChange">
    <van-collapse-item title="【押金】{{rental.realDepositStr}}" name="1">
      <view class="view-row">
        <view class="left-column">【免押金】</view>
        <view class="right-column">
          {{rental.noGuaranty? '是' : '否'}}
        </view>
      </view>
      <view class="view-row">
        <view class="left-column">【押金】</view>
        <view class="right-column">{{rental.depositStr}}</view>
      </view>

      <view class="view-row">
        <view class="left-column">【押金减免】</view>
        <view class="right-column">
          <input style="width: 85rpx;text-align: center;" class="input" placeholder="0" bindinput="setGuarantyDiscount" />
        </view>
      </view>
      <view class="view-row">
        <view class="left-column">【押金小计】</view>
        <view class="right-column">{{rental.realDepositStr}}</view>
      </view>
    </van-collapse-item>
    <van-collapse-item title="【租金】{{totalRentalAmountStr}}【天数】{{rental.expectDays}}天 " name="2">
      <view class="view-row">
        <view class="left-column">【预计租赁天数】</view>
        <view class="right-column">
          <input class="input" style="width: 50rpx;text-align: center;" value="{{rental.expectDays}}" bindinput="setExpectDays" />
        </view>
      </view>
      <view class="view-row">
        <view class="left-column">【起租日期】</view>
        <view class="right-column">
          {{rental.startDate}}
        </view>
      </view>

      <view class="view-row">
        <view class="left-column">【预计归还日期】</view>
        <view class="right-column">
          {{rental.endDate}} 
        </view>
      </view>

      <block wx:if="{{rental.expectDays == 1}}">
        <view class="view-row">
          <view class="left-column view-row" style="align-items: center;">【场次】</view>
          <view class="right-column view-row" >
            <picker range="{{rentType}}" class="input" style="width: 100rpx" >
              <picker-view>{{rentType[0]}}</picker-view>
            </picker>
            <view class="view-row" style="margin-left: 50rpx;align-items: center;">{{rental.startDateIsWeekend?'周末':'平日'}}</view>
          </view>
        </view>
        <view>
          <view class="view-row">
            <view class="left-column">【租金】</view>
            <view class="right-column">
              {{price.priceStr}}
            </view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view>
          <fui-row style="margin-top:10rpx">
            <fui-col span="6">
              <view class="fui-col-view" style="text-align:center;margin-top: 20rpx;">日期</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="text-align:center;margin-top: 20rpx;">类型</view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align:center;margin-top: 20rpx;">价格</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="text-align:center;margin-top: 20rpx;">减免</view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align:center;margin-top: 20rpx;">小计</view>
            </fui-col>
          </fui-row>
          <fui-row style="margin-top:10rpx" wx:for="{{rentalDetails}}">
            <fui-col span="6">
              <view class="fui-col-view" style="text-align:center;">{{item.date}}</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="text-align:center;">{{item.isWeekend}}</view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align: right;">{{item.priceStr}}</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="margin-left: 30rpx;text-align: center;display: flex;">
                <input class="input" style="height: 50rpx; width: 50rpx;" placeholder="0" />
              </view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align: right;">{{item.priceStr}}</view>
            </fui-col>
          </fui-row>
          
          <fui-row style="margin-top:10rpx">
            <fui-col span="6">
              <view class="fui-col-view" style="text-align:center;">总计：</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="text-align:center;">{{rentalDetails.length}}天</view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align: right;">¥410.00</view>
            </fui-col>
            <fui-col span="5">
              <view class="fui-col-view" style="margin-left: 30rpx;text-align: center;display: flex;">
                ¥0.00
              </view>
            </fui-col>
            <fui-col span="4">
              <view class="fui-col-view" style="text-align: right;">¥410.00</view>
            </fui-col>
          </fui-row>
        </view>
      </block>
      <view class="view-row">
        <view class="left-column">【招待】</view>
        <view class="right-column">
          <checkbox-group>
            <checkbox></checkbox>
          </checkbox-group>
        </view>
      </view>
    </van-collapse-item>
  </van-collapse>
</view>