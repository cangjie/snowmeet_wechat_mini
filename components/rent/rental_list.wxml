<view wx:for="{{rentals}}" wx:for-item="rental" bind:click="del" id="{{index}}">
  <view style="height: 50rpx;"></view>
  <view wx:if="{{rental.package_id == null || rental.package_id == undefined}}" class="view-row">
    <view class="number-label" style="margin-top: 100rpx;font-size: 9pt;">【{{rental.rentItems[0].itemIndex}}】</view>
    <view style="width: 650rpx; background-color: #FFF0F0;">
      <view class="view-row">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【编码】</view>
        <view class="right-column view-row" style="width: 240rpx;">
          {{rental.rentItems[0].noCode? '无' : (rental.rentItems[0].code?rental.rentItems[0].code:'')}}
          <!--input class="input" style="width: 145rpx;" value="{{rental.rentItems[0].code==null?'':rental.rentItems[0].code}}" /-->

          <!--van-icon name="scan" size="19px" /-->

        </view>
        <view class="left-column" style="width: 160rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【品类】</view>
        <view class="right-column" style="width: 75rpx;">
          {{rental.rentItems[0].category.name}}
        </view>
      </view>
      <!--view class="view-row">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【品类】</view>
        <view class="right-column right-column1 view-row" wx:if="{{rental.rentItems[0].category}}">
          <view style="width: 350rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">
            {{rental.rentItems[0].category.name}}
          </view>
          <view>
            <van-button wx:if="{{rental.rentItems[0].noCode}}" type="primary" round size="mini" bind:click="searchListBarcodeFuzzy" id="{{rental.rentItems[0].itemIndex}}" bind:click="selectCategory">重选</van-button>
          </view>
        </view>
        <view class="right-column right-column1" wx:else>
          <van-button wx:if="{{rental.rentItems[0].noCode}}" type="primary" round size="mini" bind:click="searchListBarcodeFuzzy" id="{{rental.rentItems[0].itemIndex}}" bind:click="selectCategory">选择</van-button>
        </view>
      </view-->
      <view class="view-row">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【名称】</view>
        <view class="right-column right-column1" wx:if="{{rental.rentItems[0].noCode}}">
          <input class="input" style="width: 450rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}" value="{{rental.rentItems[0].name == null? '' : rental.rentItems[0].name}}" />
        </view>
        <view class="right-column right-column1" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}" wx:else>{{rental.rentItems[0].name}}</view>
      </view>
      <view class="view-row">
        <view class="left-column"></view>
        <view class="right-column"></view>
      </view>
      <view class="view-row" style="margin-bottom: 20rpx;">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【押金】</view>
        <view class="right-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">¥1000.00</view>
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【租金】</view>
        <view class="right-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">¥100.00起</view>
        <!--租金显示相关的周末价、平日价、节假日价-->
      </view>
      <view class="view-row" style="margin-bottom: 20rpx;">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【免押金】</view>
        <view class="right-column ">
          否
        </view>
        <view class="left-column"></view>
        <view class="right-column"></view>
      </view>
      <view class="view-row" style="margin-bottom: 20rpx;">
        <view class="left-column" style="color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【起租日】</view>
        <view class="right-column " style="width: 200rpx;">
          2025-11-29
        </view>
        <view class="left-column"></view>
        <view class="right-column"></view>
      </view>
      <view class="view-row" style="margin-bottom: 20rpx;">
        <view class="left-column" style="width: 170rpx;color:{{rental.rentItems[0].textColor?rental.rentItems[0].textColor:defaultTextColor}}">【状态】
        </view>
        <view class="right-column" style="width: 165rpx;">
          已发放
        </view>
      </view>
      <view class="view-row" style="justify-content: center;margin-top: 20rpx;">
        <van-button type="info" style="margin-left: 20rpx;">暂存</van-button>
        <van-button type="warning" style="margin-left: 20rpx;">更换</van-button>
        <van-button type="primary" style="margin-left: 20rpx;">归还</van-button>
        <van-button type="danger" style="margin-left: 20rpx;">丢失</van-button>
      </view>
      <view class="view-row" style="justify-content: center; margin-bottom: 10rpx;margin-top: 20rpx;">
        <van-button plain type="primary" disabled="{{rental.rentItems[0].category_id == null}}" bind:click="showItem" id="{{index}}">
          查 看 租 金 明 细
        </van-button>
      </view>
    </view>
  </view>
  <block wx:else>
    <view class="view-row">
      <view class="number-label"></view>
      <view style="width: 650rpx;background-color: #F0FFF0;">
        <view class="view-row">
          <view class="left-column">【套餐】</view>
          <view class="right-column right-column1">{{rental.name}}</view>
        </view>
        <view class="view-row" style="margin-bottom: 20rpx;">
          <view class="left-column">【押金】</view>
          <view class="right-column">¥1000.00</view>
          <view class="left-column">【租金】</view>
          <view class="right-column">¥100.00起</view>
        </view>
        <view class="view-row" style="margin-bottom: 20rpx;">
          <view class="left-column">【免押金】</view>
          <view class="right-column">
            否
          </view>
          <view class="left-column"></view>
          <view class="right-column"></view>
        </view>
        <view class="view-row" style="margin-bottom: 20rpx;">
          <view class="left-column">【起租日】</view>
          <view class="right-column" style="width: 200rpx;">
            2025-11-29
          </view>
          <view class="left-column"></view>
          <view class="right-column"></view>
        </view>
        <view class="view-row" style="justify-content: center; margin-bottom: 10rpx;">
          <van-button plain type="primary" bind:click="showPackage" id="{{index}}"> 查 看 租 金 明 细 </van-button>
        </view>
      </view>
    </view>
    <block wx:for="{{rental.rentItems}}">

      <view class="view-row">
        <view class="number-label" style="margin-top: 50rpx;font-size: 9pt;">
          【{{item.itemIndex}}】
        </view>
        <view style="display:flex;justify-content: center; width: 650rpx; background-color: #F0FFF0;" id="{{item.itemIndex}}">
          <view style="width: 630rpx; background-color: #FFF0FF">
            <view class="view-row" style="margin-bottom: 20rpx;">
              <view class="left-column" style="width:140rpx; color:{{item.textColor?item.textColor:defaultTextColor}}">【编码】</view>
              <view class="right-column view-row" style="width:160rpx;color:{{item.textColor?item.textColor:defaultTextColor}};margin-right: 10rpx;">
                {{item.noCode? '无' : (item.code?item.code:'')}}
              </view>
              <view class="left-column" style="width: 160rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【品类】</view>
              <view class="right-column" style="width: 180rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">
                {{item.categoryName}}
              </view>
            </view>
            <view class="view-row">
              <view class="left-column" style="width:140rpx; color:{{item.textColor?item.textColor:defaultTextColor}}">【名称】</view>
              <view class="right-column right-column1">{{item.name == null? '' : item.name}}</view>
            </view>
            <view class="view-row" style="margin-bottom:20rpx">
              <view class="left-column" style="width:140rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【不需要】</view>
              <view class="right-column" style="width:240rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">
                否
              </view>
              <view class="left-column" style="width: 140rpx;color:{{item.textColor?item.textColor:defaultTextColor}}">【状态】
              </view>
              <view class="right-column" style="width: 95rpx;margin-left: 10rpx;">
                已发放
              </view>
            </view>
            <view class="view-row" style="justify-content: center;margin-top: 20rpx;">
              <van-button type="info" style="margin-left: 20rpx;">暂存</van-button>
              <van-button type="warning" style="margin-left: 20rpx;">更换</van-button>
              <van-button type="primary" style="margin-left: 20rpx;">归还</van-button>
              <van-button type="danger" style="margin-left: 20rpx;">丢失</van-button>
            </view>
            <view style="width: 630rpx;background-color: #F0FFF0;height: 10rpx;"></view>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>