/* components/reception/reception_member_bar/reception_member_bar.wxss */

.member-bar {
  --primary: #006495;
  --primary-fixed: #cbe6ff;
  --on-primary-container: #003b5b;
  --secondary: #545f73;
  --secondary-container: #d5e0f8;
  --on-secondary-container: #586377;
  --on-surface: #0b1c30;
  --on-surface-variant: #3f4850;
  --outline-variant: #bfc7d1;
  --surface-container-lowest: #ffffff;
  --surface-container: #e5eeff;

  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  padding: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px;
}

.member-avatar {
  width: 40px;
  height: 40px;
  border-radius: 999px;
  background: var(--secondary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar-text {
  font-size: 12px;
  font-weight: 700;
  color: var(--on-secondary-container);
  letter-spacing: 0.6px;
}

.member-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.member-row--bottom { margin-top: 2px; }

.member-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--on-surface);
  /* 长姓名截断，避免顶到右侧手机号 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 1;
  min-width: 0;
}
.member-cell {
  font-size: 13px;
  color: var(--on-surface-variant);
  margin-left: 6px;
  flex-shrink: 0;
}

.member-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}
.member-tag {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.4px;
  white-space: nowrap;
}
.tag-biz  { background: var(--primary-fixed); color: var(--on-primary-container); }

.member-detail-link {
  display: flex;
  align-items: center;
  gap: 2px;
  color: var(--primary);
  font-size: 12px;
  font-weight: 600;
  flex-shrink: 0;
}
