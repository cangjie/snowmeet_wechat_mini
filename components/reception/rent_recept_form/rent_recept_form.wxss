/* components/reception/rent_recept_form/rent_recept_form.wxss
   Alpine Operational Minimalist 主题 */

.rent-recept-form {
  --primary: #006495;
  --on-primary: #ffffff;
  --primary-fixed: #cbe6ff;
  --on-primary-container: #003b5b;
  --secondary: #545f73;
  --secondary-container: #d5e0f8;
  --on-secondary-container: #586377;
  --on-surface: #0b1c30;
  --on-surface-variant: #3f4850;
  --outline: #6f7881;
  --outline-variant: #bfc7d1;
  --surface-container-lowest: #ffffff;
  --surface-container-low: #eff4ff;
  --surface-container: #e5eeff;
  --surface-container-high: #dce9ff;
  --surface-variant: #d3e4fe;
  --error: #ba1a1a;
  --error-container: #ffdad6;

  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  /* 给底部固定栏（动作条 + 结算栏 + reception-tabbar）腾空间 */
  padding-bottom: calc(180px + env(safe-area-inset-bottom));
}

/* Segmented control */
.seg-control {
  display: flex;
  background: var(--surface-variant);
  padding: 4px;
  border-radius: 8px;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  color: var(--on-surface-variant);
}
.seg-item.active {
  background: var(--surface-container-lowest);
  color: var(--primary);
  box-shadow: 0 1px 2px rgba(11, 28, 48, 0.06);
}

/* Empty state */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 16px;
  gap: 8px;
}
.empty-icon {
  width: 88px;
  height: 88px;
  border-radius: 999px;
  background: var(--surface-container-low);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}
.empty-title { font-size: 16px; font-weight: 600; color: var(--on-surface); }
.empty-desc { font-size: 13px; color: var(--on-surface-variant); }

/* Rental list */
.rent-list { display: flex; flex-direction: column; gap: 10px; }

/* 套餐外卡 */
.pkg-card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  overflow: hidden;
}
.pkg-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
}
.pkg-row-name-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6px;
  overflow: hidden;
}
.pkg-row-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--on-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pkg-row-name--pending { color: var(--error); }
.pkg-row-meta {
  display: flex;
  gap: 12px;
  flex-shrink: 0;
}
.pkg-row-meta-item { font-size: 12px; color: var(--on-surface-variant); white-space: nowrap; }
.pkg-row-chev { display: flex; align-items: center; flex-shrink: 0; }

/* 展开态：套餐名独占一行，chips/押金/箭头下沉到第二行 */
.pkg-row--expanded {
  flex-direction: column;
  align-items: stretch;
  gap: 8px;
}
.pkg-title-row {
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}
.pkg-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--on-surface);
  display: inline-block;
  white-space: nowrap;
}
.pkg-title--pending { color: var(--error); }
/* 跑马灯：3s 静止 → 8s 滚动到完全离开 → 循环（与 item-title-marquee 同款） */
.pkg-title-row--marquee .pkg-title {
  animation: pkg-title-marquee 11s linear infinite;
}
@keyframes pkg-title-marquee {
  0%, 27.27% { transform: translateX(0); }
  100%       { transform: translateX(-100%); }
}
.pkg-meta-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.pkg-meta-chips {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
  margin-right: auto;
}

/* 通用 chip */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.4px;
  flex-shrink: 0;
}
.chip-primary { background: var(--primary-fixed); color: var(--on-primary-container); }
.chip-secondary { background: var(--secondary-container); color: var(--on-secondary-container); }
.chip-success { background: #dcfce7; color: #15803d; }
.chip-pending { background: #fee2e2; color: #b91c1c; }

/* 套餐展开区 */
.pkg-detail {
  padding: 12px 14px 14px;
  border-top: 1px solid var(--surface-container-low);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 租赁形式按钮组 */
.rent-mode-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}
.rent-mode-wrap .rent-mode { flex: 1; }
.rent-mode-mixed {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rent-mode {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
}
.rent-mode-btn {
  text-align: center;
  padding: 8px 0;
  border-radius: 8px;
  border: 1px solid var(--outline-variant);
  font-size: 12px;
  font-weight: 600;
  color: var(--on-surface-variant);
  background: var(--surface-container-lowest);
}
.rent-mode-btn--active {
  background: var(--primary);
  color: var(--on-primary);
  border-color: var(--primary);
}
.rent-mode-btn--disabled {
  opacity: 0.4;
}

/* KV row */
.kv-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.kv-cell {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 8px;
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.kv-label { font-size: 10px; font-weight: 700; color: var(--secondary); letter-spacing: 0.4px; }
.kv-input-wrap { display: flex; align-items: center; gap: 4px; }
.kv-prefix { font-size: 12px; font-weight: 600; color: var(--on-surface); }
.kv-input {
  flex: 1;
  font-size: 14px;
  color: var(--on-surface);
  background: transparent;
  height: 22px;
}
.kv-picker-text { font-size: 13px; color: var(--on-surface); padding: 2px 0; }

/* 起租日期：日期文字 + 今天/明天 快捷按钮 */
.date-row { display: flex; align-items: center; gap: 8px; }
.date-tap {
  flex: 1;
  font-size: 13px;
  color: var(--on-surface);
  padding: 2px 0;
  min-width: 0;
}
.date-quick { display: flex; gap: 4px; flex-shrink: 0; }
.date-quick-btn {
  font-size: 11px;
  font-weight: 600;
  color: var(--primary);
  background: var(--surface-variant);
  padding: 2px 8px;
  border-radius: 999px;
  line-height: 1.5;
}
.date-quick-btn:active { background: var(--surface-container-high); }

/* 内层装备 */
.pkg-inner {
  background: var(--surface-container-low);
  padding: 10px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.item-card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 8px;
  padding: 10px 12px;
}
.item-card--expanded { padding-bottom: 14px; }
.item-card--disabled {
  background: var(--surface-container);
  color: var(--on-surface-variant);
}
.item-card--disabled .item-title { color: var(--on-surface-variant); }
.item-head { display: flex; align-items: center; gap: 10px; }
.item-head-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
.item-title-wrap {
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}
.item-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--on-surface);
  display: inline-block;
  white-space: nowrap;
}
/* 跑马灯：3s 静止 → 8s 线性滚动到完全离开 → 循环（回到原位再静 3s） */
.item-title-wrap--marquee .item-title {
  animation: item-title-marquee 11s linear infinite;
}
@keyframes item-title-marquee {
  0%, 27.27% { transform: translateX(0); }
  100%       { transform: translateX(-100%); }
}
.item-head-right { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }

.item-form {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px dashed var(--outline-variant);
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label { font-size: 12px; font-weight: 600; color: var(--on-surface-variant); }
.form-input {
  height: 36px;
  border: 1px solid var(--outline-variant);
  border-radius: 8px;
  padding: 0 10px;
  font-size: 13px;
  color: var(--on-surface);
  background: var(--surface-container-lowest);
  width: 100%;
  box-sizing: border-box;
}
.form-input--inline { flex: 1; }
.form-input-placeholder { color: var(--outline); }
.form-input[disabled] {
  background: var(--surface-container);
  color: var(--outline);
}
.code-row { display: flex; align-items: stretch; gap: 8px; }
.code-scan-btn {
  background: var(--surface-container-high);
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.code-scan-btn--disabled {
  opacity: 0.4;
}
.code-flag-row { display: flex; gap: 8px; margin-top: 6px; }
.code-flag-btn {
  flex: 1;
  text-align: center;
  padding: 6px 0;
  border-radius: 8px;
  border: 1px solid var(--outline-variant);
  font-size: 12px;
  font-weight: 600;
  color: var(--on-surface-variant);
  background: var(--surface-container-lowest);
}
.code-flag-btn--on {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--on-primary);
}
.code-flag-btn--warn {
  background: var(--error);
  border-color: var(--error);
  color: #ffffff;
}

/* 左划删除 */
.rent-swipe { border-radius: 12px; overflow: hidden; }
.swipe-delete {
  width: 72px;
  height: 100%;
  background: var(--error);
  color: #ffffff;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Bottom stack：浮在 reception-tabbar 之上 */
.bottom-stack {
  position: fixed;
  left: 0;
  /* tabbar 高度 56 + 安全区 */
  bottom: calc(56px + env(safe-area-inset-bottom));
  width: 100%;
  z-index: 40;
}

.action-bar {
  background: var(--surface-container-lowest);
  border-top: 1px solid var(--outline-variant);
  padding: 8px 12px;
  display: flex;
  gap: 8px;
}
.action-item {
  flex: 1;
  background: var(--surface-variant);
  border-radius: 8px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 6px 4px;
  color: var(--primary);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
}
.action-item:active { background: var(--surface-container-high); }

.checkout-bar {
  background: #ffffff;
  border-top: 1px solid #f1f5f9;
  padding: 8px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.checkout-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
  flex-wrap: wrap;
}
.checkout-count {
  font-size: 11px;
  font-weight: 700;
  color: var(--on-primary);
  background: var(--primary);
  padding: 2px 8px;
  border-radius: 999px;
  flex-shrink: 0;
  letter-spacing: 0.3px;
}
.checkout-deposit {
  font-size: 16px;
  font-weight: 800;
  color: var(--primary);
  line-height: 1.2;
  white-space: nowrap;
}
.checkout-reduce { font-size: 11px; font-weight: 600; color: var(--error); white-space: nowrap; }
.checkout-rent { font-size: 12px; font-weight: 600; color: #374151; white-space: nowrap; }
.checkout-btn {
  background: var(--primary);
  color: var(--on-primary);
  border-radius: 999px;
  padding: 0 18px;
  height: 36px;
  font-size: 14px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4px 10px -6px rgba(0, 100, 149, 0.5);
  flex-shrink: 0;
}
.checkout-btn::after { border: none; }
.checkout-btn--disabled,
button[disabled].checkout-btn {
  background: var(--surface-container-high);
  color: var(--on-surface-variant);
  box-shadow: none;
}
