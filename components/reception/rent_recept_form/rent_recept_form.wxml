<!--components/reception/rent_recept_form/rent_recept_form.wxml
  租赁接待开单表单（第一步）
  对应 PRD §2.4.1 租赁开单流程：选择租赁商品 / 套餐 → 选择租赁物 → 选择租赁形式 → 提交 → 支付
  设计参考：pages/template/stitch/_2/index
  组件契约：
    - properties.rentals  父页传入的当前购物车
    - triggerEvent('syncRent', { rentals, needUpdate })  购物车变化
    - triggerEvent('addAction', { action })              请求父页弹出选择面板
    - triggerEvent('checkout', { rentals })              点击去结算
-->
<view class="rent-recept-form">

  <!-- 分组：按时间 / 按品种 -->
  <view class="seg-control">
    <view
      class="seg-item {{sort === 'time' ? 'active' : ''}}"
      data-value="time"
      bindtap="onSortChange">按时间</view>
    <view
      class="seg-item {{sort === 'category' ? 'active' : ''}}"
      data-value="category"
      bindtap="onSortChange">按品种</view>
  </view>

  <!-- 购物车列表 / 空态 -->
  <block wx:if="{{rentals && rentals.length > 0}}">
    <view class="rent-list">
      <block wx:for="{{rentals}}" wx:key="_key" wx:for-item="pkg" wx:for-index="ridx">
        <van-swipe-cell right-width="{{ 72 }}" custom-class="rent-swipe">
          <view class="pkg-card">
            <!-- 收起态：单行（名称 + 押金/租金 + 展开箭头） -->
            <view class="pkg-row" data-key="{{pkg._key}}" data-idx="{{ridx}}" bindtap="onTogglePkg">
              <view class="pkg-row-name-wrap">
                <text class="pkg-row-name">{{pkg._displayName}}</text>
                <view wx:if="{{pkg._kindLabel}}" class="chip chip-primary">{{pkg._kindLabel}}</view>
              </view>
              <view class="pkg-row-meta">
                <text class="pkg-row-meta-item">押金 ¥{{pkg._depositLabel}}</text>
                <text class="pkg-row-meta-item">租金/日 ¥{{pkg._dailyRate}}</text>
              </view>
              <view class="pkg-row-chev">
                <van-icon name="{{pkg._expanded ? 'arrow-up' : 'arrow-down'}}" size="16px" color="#6f7881"/>
              </view>
            </view>

            <!-- 展开态：详情 + 内层装备清单 -->
            <view wx:if="{{pkg._expanded}}" class="pkg-detail">
              <!-- 租赁形式 -->
              <view class="rent-mode">
                <block wx:for="{{rentModes}}" wx:key="key" wx:for-item="mode">
                  <view
                    class="rent-mode-btn {{pkg._modeKey === mode.key ? 'rent-mode-btn--active' : ''}}"
                    catchtap="onPkgModeTap"
                    data-ridx="{{ridx}}"
                    data-mode="{{mode.key}}">{{mode.name}}</view>
                </block>
              </view>

              <!-- 押金 / 租金 -->
              <view class="kv-row">
                <view class="kv-cell">
                  <text class="kv-label">押金</text>
                  <view class="kv-input-wrap">
                    <text class="kv-prefix">¥</text>
                    <input
                      class="kv-input"
                      type="digit"
                      value="{{pkg._depositInput}}"
                      catchblur="onPkgDepositBlur"
                      data-ridx="{{ridx}}"/>
                  </view>
                </view>
                <view class="kv-cell">
                  <text class="kv-label">租金 / 日</text>
                  <view class="kv-input-wrap">
                    <text class="kv-prefix">¥</text>
                    <input
                      class="kv-input"
                      type="digit"
                      value="{{pkg._dailyRateInput}}"
                      catchblur="onPkgRateBlur"
                      data-ridx="{{ridx}}"/>
                  </view>
                </view>
              </view>

              <!-- 起租日期 / 时间 -->
              <view class="kv-row">
                <view class="kv-cell">
                  <text class="kv-label">起租日期</text>
                  <picker
                    mode="date"
                    value="{{pkg._startDate}}"
                    bindchange="onPkgDateChange"
                    data-ridx="{{ridx}}">
                    <view class="kv-picker-text">{{pkg._startDate || '请选择'}}</view>
                  </picker>
                </view>
                <view class="kv-cell">
                  <text class="kv-label">起租时间</text>
                  <picker
                    mode="time"
                    value="{{pkg._startTime}}"
                    bindchange="onPkgTimeChange"
                    data-ridx="{{ridx}}">
                    <view class="kv-picker-text">{{pkg._startTime}}</view>
                  </picker>
                </view>
              </view>

              <!-- 内层装备 -->
              <view wx:if="{{pkg.rentItems && pkg.rentItems.length > 0}}" class="pkg-inner">
                <block wx:for="{{pkg.rentItems}}" wx:key="_key" wx:for-item="rit" wx:for-index="iidx">
                  <view class="item-card {{rit._expanded ? 'item-card--expanded' : ''}}">
                    <view
                      class="item-head"
                      data-key="{{rit._key}}"
                      data-ridx="{{ridx}}"
                      data-iidx="{{iidx}}"
                      bindtap="onToggleItem">
                      <view class="item-thumb">
                        <van-icon name="goods-collect-o" size="20px" color="#006495"/>
                      </view>
                      <view class="item-head-body">
                        <text class="item-title">{{rit._title}}</text>
                        <text wx:if="{{rit._spec}}" class="item-spec">{{rit._spec}}</text>
                      </view>
                      <view class="item-head-right">
                        <view class="chip {{rit._entered ? 'chip-success' : 'chip-pending'}}">
                          <text>{{rit._entered ? '已录入' : '待处理'}}</text>
                        </view>
                        <van-icon name="{{rit._expanded ? 'arrow-up' : 'arrow-down'}}" size="14px" color="#6f7881"/>
                      </view>
                    </view>

                    <view wx:if="{{rit._expanded}}" class="item-form">
                      <view class="form-group">
                        <view class="form-label">租赁物名称</view>
                        <input
                          class="form-input"
                          value="{{rit.name || ''}}"
                          placeholder="输入租赁物名称..."
                          placeholder-class="form-input-placeholder"
                          catchblur="onItemFieldBlur"
                          data-ridx="{{ridx}}"
                          data-iidx="{{iidx}}"
                          data-field="itemName"/>
                      </view>

                      <view class="form-group">
                        <view class="form-label">装备编码</view>
                        <view class="code-row">
                          <input
                            class="form-input form-input--inline"
                            value="{{rit.code || ''}}"
                            placeholder="输入或扫描编码"
                            placeholder-class="form-input-placeholder"
                            catchblur="onItemFieldBlur"
                            data-ridx="{{ridx}}"
                            data-iidx="{{iidx}}"
                            data-field="code"/>
                          <view class="code-scan-btn" catchtap="onItemScan" data-ridx="{{ridx}}" data-iidx="{{iidx}}">
                            <van-icon name="scan" size="20px" color="#006495"/>
                          </view>
                        </view>
                        <view class="code-flag-row">
                          <view
                            class="code-flag-btn {{rit._codeFlag === 'no_code' ? 'code-flag-btn--on' : ''}}"
                            catchtap="onItemCodeFlag"
                            data-ridx="{{ridx}}"
                            data-iidx="{{iidx}}"
                            data-flag="no_code">无编码</view>
                          <view
                            class="code-flag-btn {{rit._codeFlag === 'not_required' ? 'code-flag-btn--on' : ''}}"
                            catchtap="onItemCodeFlag"
                            data-ridx="{{ridx}}"
                            data-iidx="{{iidx}}"
                            data-flag="not_required">不需要</view>
                        </view>
                      </view>

                      <view class="form-group">
                        <view class="form-label">备注信息</view>
                        <input
                          class="form-input"
                          value="{{rit.memo || ''}}"
                          placeholder="填写板刃磨损等特殊情况..."
                          placeholder-class="form-input-placeholder"
                          catchblur="onItemFieldBlur"
                          data-ridx="{{ridx}}"
                          data-iidx="{{iidx}}"
                          data-field="note"/>
                      </view>

                      <view class="form-group">
                        <view class="form-label">租赁模式</view>
                        <view class="rent-mode">
                          <block wx:for="{{rentModes}}" wx:key="key" wx:for-item="mode">
                            <view
                              class="rent-mode-btn {{rit._modeKey === mode.key ? 'rent-mode-btn--active' : ''}}"
                              catchtap="onItemModeTap"
                              data-ridx="{{ridx}}"
                              data-iidx="{{iidx}}"
                              data-mode="{{mode.key}}">{{mode.name}}</view>
                          </block>
                        </view>
                      </view>
                    </view>
                  </view>
                </block>
              </view>
            </view>
          </view>
          <view slot="right" class="swipe-delete" data-idx="{{ridx}}" catchtap="onDeleteRental">删除</view>
        </van-swipe-cell>
      </block>
    </view>
  </block>
  <block wx:else>
    <view class="empty">
      <view class="empty-icon">
        <van-icon name="goods-collect-o" size="48px" color="#bfc7d1"/>
      </view>
      <view class="empty-title">还没有添加任何租赁商品</view>
      <view class="empty-desc">点击下方按钮开始添加</view>
    </view>
  </block>

  <!-- 底部固定区：4 个快捷入口 + 押金合计 / 去结算 -->
  <view class="bottom-stack">
    <view class="action-bar">
      <view class="action-item" data-action="package" bindtap="onAddAction">
        <van-icon name="goods-collect-o" size="22px" color="#006495"/>
        <text>添加套餐</text>
      </view>
      <view class="action-item" data-action="scan" bindtap="onAddAction">
        <van-icon name="scan" size="22px" color="#006495"/>
        <text>扫描条码</text>
      </view>
      <view class="action-item" data-action="search" bindtap="onAddAction">
        <van-icon name="search" size="22px" color="#006495"/>
        <text>搜索单品</text>
      </view>
      <view class="action-item" data-action="noCode" bindtap="onAddAction">
        <van-icon name="apps-o" size="22px" color="#006495"/>
        <text>无码物品</text>
      </view>
    </view>

    <view class="checkout-bar">
      <view class="checkout-prices">
        <view class="checkout-price-row">
          <text class="checkout-label">押金总计</text>
          <text class="checkout-deposit">¥{{summary.depositLabel}}</text>
        </view>
        <view class="checkout-sub-row">
          <text wx:if="{{summary.depositReduce > 0}}" class="checkout-reduce">押金减免 -¥{{summary.depositReduceLabel}}</text>
          <text class="checkout-rent">租金 ¥{{summary.rentLabel}}</text>
        </view>
      </view>
      <button
        class="checkout-btn {{rentals.length === 0 ? 'checkout-btn--disabled' : ''}}"
        disabled="{{rentals.length === 0}}"
        bindtap="onCheckout">
        去结算
        <van-icon name="arrow" size="16px" color="#ffffff" custom-style="margin-left:6px"/>
      </button>
    </view>
  </view>

</view>
