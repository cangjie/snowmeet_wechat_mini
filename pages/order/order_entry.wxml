<view>
  <view wx:if="{{order}}" style="margin-top: 20rpx;">
    <fui-row>
      <fui-col span="6">
        <view class="fui-left-column">店铺：</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column">{{order.shop}}</view>
      </fui-col>
    </fui-row>
    <fui-row>
      <fui-col span="6">
        <view class="fui-left-column">订单号：</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column">{{order.code}}</view>
      </fui-col>
    </fui-row>
    <view style="height: 50rpx;"></view>
    <fui-section title="请确认您的订单内容" isLine></fui-section>
    <view wx:if="{{order.type=='餐饮'}}" style="margin-top: 20rpx;">
      <fui-row>
        <fui-col span="12">
          <view class="fui-left-column" style="text-align: center;">商品</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-left-column" style="text-align: center;">单价</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-right-column" style="text-align: center;">数量</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-left-column" style="text-align: center;">小计</view>
        </fui-col>
      </fui-row>
      <fui-row wx:for="{{order.fdOrders}}">
        <fui-col span="12">
          <view class="fui-left-column" style="text-align: center;">{{item.product_name}}</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-left-column" style="text-align: right;">{{item.unit_priceStr}}</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-right-column" style="text-align: center;">{{item.count}}</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-left-column" style="text-align: right;margin-right: 20rpx;">{{item.summaryStr}}</view>
        </fui-col>
      </fui-row>
      <view style="height: 50rpx;"></view>
      <fui-section title="请确认您的订单金额" isLine></fui-section>
      <view style="height: 20rpx;" ></view>
      <fui-row>
        <fui-col span="6">
          <view class="fui-left-column">总计：</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-right-column" style="text-align: right;" >{{order.totalStr}}</view>
        </fui-col>
        <fui-col span="14"></fui-col>
      </fui-row>
      <view style="height: 20rpx;" ></view>
      <fui-row>
        <fui-col span="6">
          <view class="fui-left-column">减免：</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-right-column" style="text-align: right;" >{{order.discountAmountStr}}</view>
        </fui-col>
        <fui-col span="14"></fui-col>
      </fui-row>
      <view style="height: 20rpx;"></view>
      <fui-row>
        <fui-col span="6">
          <view class="fui-left-column">需要支付：</view>
        </fui-col>
        <fui-col span="4">
          <view class="fui-right-column" style="color:red; text-align: right;">{{order.totalChargeStr}}</view>
        </fui-col>
        <fui-col span="14"></fui-col>
      </fui-row>
      <view class="view-row" style="justify-content: center;margin-top: 40rpx;" >
      <fui-button btnSize="medium" style="margin-left: 50rpx;" size="35rpx" text=" 敬 请 支 付 " background="#2EA6D0" bind:click="uploadImage"></fui-button>
      </view>
    </view>
  </view>
  <view wx:else style="display: flex;align-items: center;justify-items: center;">
    <view>请稍候……</view>
  </view>
</view>