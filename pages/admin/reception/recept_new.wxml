<!--pages/admin/reception/recept_new.wxml
  业务开单（共享页）
  对应 PRD §1.4.5 第二步：店员选业务后进入对应业务开单
  设计：参考 pages/admin/recept/recept_new 的结构（顶级页持有数据 + 调接口，
        子组件只负责渲染表单与回传事件）
  目前实现：租赁开单第一步（rent-recept-form）
-->
<view class="page-root">

  <!-- TopAppBar：标题 = 业务名 + 开单 -->
  <view class="topbar">
    <view class="topbar-back" bindtap="onBack">
      <van-icon name="arrow-left" size="22px" color="#006495"/>
    </view>
    <view class="topbar-title">{{bizLabel}}开单</view>
    <view class="topbar-back"></view>
  </view>

  <!-- 顾客信息条（所有 bizType 共用，组件化） -->
  <reception-member-bar
    customer="{{customer}}"
    shop="{{shop}}"
    bizLabel="{{bizLabel}}"
    bind:memberInfoFound="onMemberInfoFound"
    bind:memberDetail="onMemberDetail" />

  <!-- 业务表单：根据 bizType 渲染不同自定义组件 -->
  <view class="form-slot">
    <rent-recept-form
      wx:if="{{bizType === 'rent'}}"
      shop="{{shop}}"
      memberId="{{customer.memberId}}"
      rentals="{{order.rentals}}"
      bind:syncRent="onSyncRent"
      bind:addAction="onAddAction"
      bind:editRental="onEditRental"
      bind:checkout="onCheckout"
      bind:sortChange="onSortChange" />

    <view wx:if="{{bizType === 'maintain' || bizType === 'retail'}}" class="placeholder">
      <view class="placeholder-title">{{bizLabel}}开单（下一步迁移）</view>
      <view class="placeholder-desc">该业务的接待表单组件尚未迁移</view>
    </view>
  </view>

  <!-- 接待 tabbar -->
  <reception-tabbar active="open" />
</view>
