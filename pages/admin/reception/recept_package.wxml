<!--pages/admin/reception/recept_package.wxml
  添加套餐选择页
  设计参考：pages/template/stitch/_3
-->
<view class="page-root">

  <!-- TopAppBar -->
  <view class="topbar">
    <view class="topbar-back" bindtap="onClose">
      <van-icon name="arrow-left" size="22px" color="#006495"/>
    </view>
    <view class="topbar-title">选择套餐</view>
    <view class="topbar-back"></view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x class="cat-tabs">
    <view class="cat-tabs-inner">
      <block wx:for="{{categories}}" wx:key="key">
        <view
          class="cat-chip {{activeCat === item.key ? 'cat-chip--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onCatTap">
          {{item.name}}
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-hint">加载中...</view>

  <!-- 套餐列表 -->
  <scroll-view wx:else scroll-y class="pkg-scroll">
    <view class="pkg-list">
      <block wx:for="{{visiblePackages}}" wx:key="id">
        <view class="pkg-card {{item.qty > 0 ? 'pkg-card--active' : ''}}">
          <view class="pkg-head">
            <view
              class="pkg-checkbox {{item.qty > 0 ? 'pkg-checkbox--on' : ''}}"
              data-id="{{item.id}}"
              bindtap="onTogglePackage">
              <van-icon wx:if="{{item.qty > 0}}" name="success" size="14px" color="#ffffff"/>
            </view>
            <view class="pkg-body">
              <view class="pkg-title">{{item.name}}</view>
              <view wx:if="{{item.description}}" class="pkg-desc">{{item.description}}</view>
              <view wx:if="{{item.deposit}}" class="pkg-deposit">
                <text class="deposit-label">押金</text>
                <text class="deposit-value">¥{{item.deposit}}</text>
              </view>
              <view class="stepper-wrap">
                <view class="stepper">
                  <view class="stepper-btn stepper-btn--minus" data-id="{{item.id}}" bindtap="onMinus">
                    <van-icon name="minus" size="16px" color="#006495"/>
                  </view>
                  <text class="stepper-value">{{item.qty}}</text>
                  <view class="stepper-btn stepper-btn--plus" data-id="{{item.id}}" bindtap="onPlus">
                    <van-icon name="plus" size="16px" color="#ffffff"/>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:if="{{visiblePackages.length === 0}}" class="empty">该分类下暂无可选套餐</view>
    </view>
  </scroll-view>

  <!-- 底部确认栏 -->
  <view class="modal-footer">
    <view class="footer-summary">
      <view class="footer-line-1">已选 {{selectedCount}} 种（共 {{selectedQty}} 份）</view>
    </view>
    <button
      class="confirm-btn {{selectedQty === 0 ? 'confirm-btn--disabled' : ''}}"
      bindtap="onConfirm">
      确认添加
    </button>
  </view>

</view>
