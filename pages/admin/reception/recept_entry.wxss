/* pages/admin/reception/recept_entry.wxss
   Alpine Operational Minimalist tokens (mirror of pages/template/stitch/_1) */

page {
  --surface: #f8f9ff;
  --surface-container-lowest: #ffffff;
  --surface-container-low: #eff4ff;
  --surface-container: #e5eeff;
  --surface-container-high: #dce9ff;
  --surface-container-highest: #d3e4fe;
  --surface-variant: #d3e4fe;
  --on-surface: #0b1c30;
  --on-surface-variant: #3f4850;
  --outline: #6f7881;
  --outline-variant: #bfc7d1;
  --primary: #006495;
  --on-primary: #ffffff;
  --primary-container: #4aa9e9;
  --on-primary-container: #003b5b;
  --secondary: #545f73;
  --secondary-container: #d5e0f8;
  --on-secondary-container: #586377;
  --error: #ba1a1a;
  --error-container: #ffdad6;
  --on-error-container: #93000a;

  background-color: var(--surface);
  color: var(--on-surface);
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 16px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.page-root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 32px;
}

/* TopAppBar：仅标题，居中 */
.topbar {
  height: 56px;
  background-color: #ffffff;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16px;
  position: sticky;
  top: 0;
  z-index: 50;
}
.topbar-title {
  color: var(--primary);
  font-weight: 700;
  font-size: 18px;
  letter-spacing: 0.3px;
}

/* Main */
.main {
  flex: 1;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.page-header { display: flex; flex-direction: column; gap: 8px; }
.page-title {
  font-size: 24px;
  font-weight: 700;
  color: var(--on-surface);
  line-height: 1.3;
}
/* 店铺卡片（包住旧 shop-selector picker） */
.shop-card {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  border: 1px solid var(--outline-variant);
  background: var(--surface-container-low);
  border-radius: 8px;
}
.shop-card-icon { display: flex; align-items: center; }
.shop-card-label { font-size: 14px; color: var(--secondary); }
.shop-card-picker {
  flex: 1;
  font-size: 14px;
  color: var(--on-surface);
  display: flex;
  align-items: center;
  min-width: 0;
}
.shop-card-picker shop-selector,
.shop-card-picker shop-selector picker,
.shop-card-picker shop-selector picker-view {
  width: 100% !important;
  font-size: 14px;
  color: var(--on-surface);
  font-weight: 500;
}

/* Cards */
.card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 2px rgba(11, 28, 48, 0.04);
}
.card-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}
.card-header--standalone { margin-bottom: 8px; }
.card-title { font-size: 14px; font-weight: 700; color: var(--on-surface); }

/* Form */
.form-group { display: flex; flex-direction: column; margin-bottom: 12px; }
.form-group:last-child { margin-bottom: 0; }
.form-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--on-surface-variant);
  margin-bottom: 6px;
}
.form-input {
  height: 44px;
  border: 1px solid var(--outline-variant);
  background: var(--surface-container-lowest);
  border-radius: 8px;
  padding: 0 12px;
  font-size: 16px;
  color: var(--on-surface);
  width: 100%;
  box-sizing: border-box;
}
.form-input-placeholder { color: var(--outline); }
.form-input-wrap { position: relative; display: flex; align-items: center; }
.form-input-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  pointer-events: none;
}
.form-input-suffix {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
}
.form-input--with-icon { padding-left: 38px; padding-right: 38px; }

/* Segmented control */
.seg-control {
  display: flex;
  background: var(--surface-container-low);
  border-radius: 8px;
  padding: 4px;
  height: 44px;
}
.seg-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  color: var(--secondary);
  transition: all 0.15s ease;
}
.seg-item.active {
  background: var(--surface-container-lowest);
  color: var(--primary);
  box-shadow: 0 1px 2px rgba(11, 28, 48, 0.06);
}

/* Hints */
.hint {
  margin-top: 6px;
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 4px;
}
.hint-primary { color: var(--primary); }
.hint-muted { color: var(--on-surface-variant); }

/* Section */
.section { display: flex; flex-direction: column; gap: 8px; }

/* Business type cards：直接点击进入开单 */
.biz-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
.biz-card {
  position: relative;
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  padding: 16px 12px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  overflow: hidden;
  box-shadow: 0 1px 2px rgba(11, 28, 48, 0.04);
  transition: transform 0.1s ease;
}
.biz-card:active { transform: scale(0.97); border-color: var(--primary); }
.biz-card--disabled {
  opacity: 0.45;
  background: var(--surface-container-low);
}
.biz-card--disabled:active { transform: none; border-color: var(--outline-variant); }
.biz-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 999px;
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
}
.biz-label { font-size: 12px; font-weight: 600; color: var(--on-surface); }
.biz-arrow {
  position: absolute;
  bottom: 6px;
  right: 8px;
  color: var(--outline);
}
.biz-hint {
  text-align: center;
  font-size: 12px;
  color: var(--on-surface-variant);
  margin-top: 6px;
}

/* Recover link */
.recover-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: var(--primary);
  font-size: 14px;
  font-weight: 600;
  padding: 12px;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
