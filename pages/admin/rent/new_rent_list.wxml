<view wx:if="{{staff && staff.title_level >= 100}}" style="margin-top: 50rpx;">
  <fui-card full>
    <fui-row>
      <fui-col span="5">
        <view class="fui-left-column">【店铺】</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column">
          <shop-selector bindShopSelected="shopSelected" defaultShop="崇礼旗舰店"></shop-selector>
        </view>
      </fui-col>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【日期】</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column view-row">
          <picker id="start" mode="date" class="input" style="margin-right:20rpx;" disabled="{{querying}}" bindchange="setDate">
            <picker-view>{{startDate}}</picker-view>
          </picker>
          -
          <picker id="end" mode="date" class="input" style="margin-left:20rpx;" disabled="{{querying}}" bindchange="setDate">
            <picker-view>{{endDate}}</picker-view>
          </picker>
        </view>
      </fui-col>
    </fui-row>
  </fui-card>
  <view style="height: 20rpx;"></view>
  <fui-card full>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【测试】</view>
      </fui-col>
      <radio-group id="isTest" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="false">营业</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="{{true}}">测试</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="null">全部</radio>
        </fui-col>

      </radio-group>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【招待】</view>
      </fui-col>
      <radio-group id="isEntertain" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="false">正常</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="true">招待</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="null">全部</radio>
        </fui-col>
      </radio-group>
    </fui-row>
