  </mp-cells>
  <fui-backdrop show="{{showBackdrop}}" closable>
    <confirm-rental wx:if="{{showBackdrop && backDropType == 'confirm_rental'}}" rentalId="{{currentRentalId}}"
      bindCloseBackdrop="closeBackdrop"></confirm-rental>
  </fui-backdrop>
  <van-popup show="{{ showSelectPackagePopUp }}">
    <package_selector bindConfirm="selectPackageConfirm" bindCancel="cancelPackagePopUp"></package_selector>
  </van-popup>
  <van-popup show="{{showSelectCategoryPopUp}}">
    <category-selector bindCancel="cancelCategoryPopUp" bindConfirm="confirmCategory"></category-selector>
  </van-popup>
  <van-popup show="{{showAppendPay}}" closeable close-icon-position="top-right" bind:close="closeAppendPay">
    <view style="width: 700rpx;height:700rpx">
      <view>
        支付追加押金：{{order.paying_amountStr}}
      </view>
      <payment orderId="{{order.id}}" wx:if="{{showAppendPay}}" bindOrderStatusChanged="orderStatusChanged"
        bindOrderPaidResult="dealPaidResult"></payment>
    </view>
  </van-popup>
  <fui-backdrop show="{{showBackdrop && backDropType != 'confirm_rental' }}" closable>
    <scroll-view style="height: 90vh;margin-left: auto;margin-right: auto;" scroll-y>
      <block wx:if="{{action == 'package'}}">
        <fui-card title="套餐名称：{{currentRental.name}}" tag="共{{currentRental.rentItems.length}}件">
          <view class="fui-card__content" style="width: 650rpx; margin-top:50rpx;height: {{windowHeight}}rpx">
            <scroll-view scroll-y="true" style="height: {{windowHeight }}rpx">
              <rent_charge rentItem="{{currentRental}}" bindRentalUpdated="onRentalChange"
                bindRentalChange="onRentalChange" shop="{{shopObj}}"></rent_charge>
            </scroll-view>
          </view>
          <view class="view-row" style="margin-top: 50rpx;margin-bottom: 50rpx;">
            <button class="input" size="mini" bindtap="cancelBackdrop"> 取 消 </button>
            <button class="input" size="mini" bindtap="saveUpdatedRental"> 保 存 </button>
          </view>
        </fui-card>
      </block>
      <block wx:if="{{action == 'item'}}">
        <view style="background-color: white;width:650rpx;margin-left: auto;margin-right: auto;">
          <view style="height: 10rpx;"></view>
          <view class="view-row" style="height: 35rpx;">
            <view class="left-column" style="width: 150rpx;height:35rpx">【品类】</view>
            <view class="right-column" style="width: 500rpx;height:35rpx">
              {{currentRental.rentItems[0].category.name}}
            </view>
          </view>
          <view class="view-row" style="height: 35rpx;">
            <view class="left-column" style="width: 150rpx;height: 35rpx;">【编码】</view>
            <view class="right-column view-row" style="width: 500rpx;height: 35rpx;">
              {{currentRental.rentItems[0].noCode? '【无】' : currentRental.rentItems[0].code}}
            </view>
          </view>
          <view class="view-row" style="height: 35rpx;">
            <view class="left-column" style="width: 150rpx;height: 35rpx;">【名称】</view>
            <view class="right-column" style="width: 500rpx;height: 35rpx;">
              {{currentRental.rentItems[0].name? currentRental.rentItems[0].name: ''}}
            </view>
          </view>
          <view style="height: 20rpx;"></view>
          <rent_charge rentItem="{{currentRental}}" bindRentalUpdated="onRentalChange" bindRentalChange="onRentalChange"
            shop="{{shopObj}}"></rent_charge>
          <view class="view-row" style="margin-top: 50rpx;margin-bottom: 50rpx;">
            <button class="input" size="mini" bindtap="cancelBackdrop"> 取 消 </button>
            <button class="input" size="mini" bindtap="saveUpdatedRental"> 保 存 </button>
          </view>
          <view style="height: 50rpx;"></view>
        </view>
      </block>
      <block wx:if="{{action == 'priceList'}}">
        <rent-price-list shopName="{{shop}}" type="{{type}}" dayType="{{dayType}}" targetId="{{targetId}}"
          memberId="{{memberId}}"></rent-price-list>
        <view class="view-row" style="width: 90%;background-color: white;margin-left: auto;margin-right: auto;">
          <button class="input" size="mini" bindtap="cancelBackdrop" style="margin-top:50rpx;margin-bottom: 50rpx;"> 关 闭
          </button>
        </view>
      </block>
    </scroll-view>
  </fui-backdrop>
  <van-calendar show="{{ showCalendar }}" bind:close="onCloseCalendar" bind:confirm="onConfirmCalendar" />
</view>