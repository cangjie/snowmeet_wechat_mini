<view>
  <mp-cells title="订单信息"  >
    <mp-cell ext-class="my-cell"   >
      <view class="view-row" >
        <view class="left-column"  >【订单号】</view>
        <view class="right-column"  >{{order.code}}</view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell" >
      <view class="view-row">
        <view class="left-column">【店铺】</view>
        <view class="right-column">{{order.shop}}</view>
        <view class="left-column">【会员】</view>
        <view class="right-column">{{order.member.following_wechat == 1 ? '会员' : '散客'}}</view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell" >
      <view class="view-row" style="height: 24rpx;align-items: center;">
        <view class="view-row left-column" style="height: 24rpx;align-items: center;" >【姓名】</view>
        <view class="view-row right-column" style="height: 24rpx;align-items: center;" >{{order.member.title}}</view>
        <view class="view-row left-column" style="height: 24rpx;align-items: center;" >【电话】</view>
        <view class="view-row right-column" style="height: 24rpx;align-items: center;" >
          <van-button  size="small" id="{{order.member.cell}}" bind:click="call" type="info" >{{order.member.cell}}</van-button>
        </view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell" >
      <view class="view-row">
        <view class="left-column">【业务日期】</view>
        <view class="right-column">{{order.bizDateStr}}</view>
        <view class="left-column">【业务时间】</view>
        <view class="right-column">{{order.bizTimeStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【关闭日期】</view>
        <view class="right-column">{{order.close_dateDateStr}}</view>
        <view class="left-column">【关闭时间】</view>
        <view class="right-column">{{order.close_dateTimeStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【单品数量】</view>
        <view class="right-column">{{order.categoryNum}}</view>
        <view class="left-column">【套餐数量】</view>
        <view class="right-column">{{order.packageNum}}</view>
      </view>
    </mp-cell>
  </mp-cells>
  <mp-cells title="支付信息">
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【支付总笔数】</view>
        <view class="right-column" style="width: 150rpx;">{{order.availablePayments.length}}</view>
        <view class="left-column" style="width: 200rpx;">【支付总金额】</view>
        <view class="right-column" style="width: 150rpx;">{{order.paidAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【退款总笔数】</view>
        <view class="right-column" style="width: 150rpx;">{{order.availableRefunds.length}}</view>
        <view class="left-column" style="width: 200rpx;">【退款总金额】</view>
        <view class="right-column" style="width: 150rpx;">{{order.refundAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【在押押金】</view>
        <view class="right-column" style="width: 150rpx;">{{order.unRelieveGuarantyStr}}</view>
        <view class="left-column" style="width: 200rpx;">【解押押金】</view>
        <view class="right-column" style="width: 150rpx;">{{order.rentProperties.relieveGuarantyAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" style="justify-content: center;">
        <van-button type="info" size="small" > 收 支 明 细 </van-button>
      </view>
    </mp-cell>
  </mp-cells>
  <van-tabs active="{{ activeTabIndex }}" bind:change="onTabChange">
    <van-tab title="按租赁商品">
      <mp-cells wx:for="{{order.rentals}}" title="{{item.titleName}}">
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【起租日期】</view>
            <view class="right-column">{{item.realStartDateStr}}</view>
            <view class="left-column">【退租日期】</view>
            <view class="right-column">{{item.realEndDateStr}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【押金】</view>
            <view class="right-column">{{item.guarantyAmountStr}}</view>
            <view class="left-column">【状态】</view>
            <view class="right-column">
            {{item.settled == 1 ?   ((item.realStartDate == null && item.realEndDate == null)? '已取消' :  '已结算' ) : '在租'}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【租金】</view>
            <view class="right-column">{{item.totalRentalAmountStr}}</view>
            <view class="left-column">【减免】</view>
            <view class="right-column">{{item.totalDiscountAmountStr}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【赔偿】</view>
            <view class="right-column">{{item.totalRepairationAmountStr}}</view>
            <view class="left-column">【超时】</view>
            <view class="right-column">{{item.totalOvertimeAmountStr}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【招待】</view>
            <view class="right-column">{{item.entertain == true ? '是' : '否'}}</view>
            <view class="left-column">【小计】</view>
            <view class="right-column">{{item.totalSummaryStr}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【备注】</view>
            <view  class="right-column" style="width: 75%;" >
              <input class="input" disabled="{{item.moddingMemo!=true}}" 
              id="{{index}}" value="{{item.memo}}" bindinput="setMemo" ></input>
            </view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row" style="justify-content: center;">
            <block wx:if="{{item.moddingMemo==true}}" >
              <van-button  type="warning" size="small" id="{{index}}" 
              bind:click="modMemoCancel" >取消</van-button>
              <van-button  type="danger" size="small" id="{{index}}" 
              bind:click="modMemoConfirm" style="margin-left: 30rpx;" >确认</van-button>
            </block>
            <van-button wx:else type="warning" size="small" id="{{index}}" bind:click="modMemo" >修改备注</van-button>
            <van-button type="info" size="small" id="{{item.id}}" bind:click="showRentalDetail" 
            disabled="{{item.entertain}}" style="margin-left: 30rpx;" >租金明细</van-button>
            <van-button id="{{item.id}}" type="primary" size="small" style="margin-left: 30rpx;" bind:click="showRentItem">租赁物明细</van-button>
          </view>
        </mp-cell>
      </mp-cells>
    </van-tab>
    <van-tab title="按租赁物">
      <mp-cells wx:for="{{order.rentals}}" wx:for-item="rental" title="{{rental.titleName}}" wx:if="{{currentRentalId == null || (currentRentalId == rental.id) }}">
        <block wx:for="{{rental.rentItems}}">
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【名称】</view>
              <view class="right-column" style="width: 500rpx;">{{item.noNeed == true ? '--' : item.name}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【编码】</view>
              <view class="right-column">{{item.noNeed == true ? '--' : (item.noCode == true? '无编码' : item.code)}}</view>
              
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【分类】</view>
              <view class="right-column" style="width: 550rpx;">{{item.noNeed == true ? '' : item.category.name}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【发放日期】</view>
              <view class="right-column">{{item.noNeed == true ? '--' : item.pickDateStr}}</view>
              <view class="left-column">【发放时间】</view>
              <view class="right-column">{{item.noNeed == true ? '--' : item.pickTimeStr}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【归还日期】</view>
              <view class="right-column">{{item.noNeed == true ? '--' : item.returnDateStr}}</view>
              <view class="left-column">【归还时间】</view>
              <view class="right-column">{{item.noNeed == true ? '--' : item.returnTimeStr}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【状态】</view>
              <view class="right-column">{{item.noNeed == true ? '不需要'  : item.status}}</view>
              <view class="left-column"></view>
              <view class="right-column"></view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【发放人】</view>
              <view class="right-column">{{item.noNeed == true ? '' : (item.pickStaff? item.pickStaff.name: '--')}}</view>
              <view class="left-column">【接收人】</view>
              <view class="right-column">{{item.noNeed == true ? '' : (item.returnStaff? item.returnStaff.name: '--')}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【赔偿】</view>
              <view class="right-column">
                <input class="input" id="{{item.id}}" bindblur="setRepairAmount" value="{{item.totalRepairationAmount}}"
                disabled="{{item.setRepairing != true}}" type="number" style="text-align: center;" />
              </view>
              <view class="view-row" style="justify-content: center;align-items: center;" >
                <van-button wx:if="{{item.setRepairing != true}}"  type="danger" size="small" style="margin-left: 50rpx;" 
                  id="{{item.id}}" bind:click="setRepair" >赔偿</van-button>
                <block wx:else >
                  <van-button type="warning" size="small" style="margin-left: 50rpx;" 
                  id="{{item.id}}" bind:click="setRepairCancel" >取消</van-button>
                  <van-button type="danger" size="small" style="margin-left: 50rpx;" 
                  id="{{item.id}}" bind:click="setRepairConfirm" >确认</van-button>
                </block>
              </view>
            </view>
          </mp-cell>
          <mp-cell wx:if="{{item.noNeed != true}}">
            <view class="view-row" style="justify-content: center;">
              <van-button type="primary" size="small" wx:if="{{item.status == '已发放' }}" id="{{item.id}}" bind:click="setReturn">归还</van-button>
              <van-button type="primary" size="small" wx:if="{{item.status == '已归还' }}" id="{{item.id}}" bind:click="setUnReturn" disabled="{{order.refundAmount > 0}}" >设置未归还</van-button>
              <van-button type="primary" size="small" id="{{item.id}}" bind:click="setPick" wx:if="{{item.status == '已暂存' || item.status == '未发放' }}">发放</van-button>
              <van-button type="warning" size="small" style="margin-left: 50rpx;" id="{{item.id}}" wx:if="{{item.status=='已发放'}}" bind:click="setStore">暂存</van-button>
              
              <van-button type="info" size="small" style="margin-left: 50rpx;" id="{{item.id}}">发还记录</van-button>
            </view>
          </mp-cell>
        </block>
      </mp-cells>
      <view class="view-row" style="justify-content: center;" wx:if="{{currentRentalId != null}}">
        <van-button type="info" bind:click="showAllRentItem"> 查 看 全 部 </van-button>
      </view>
    </van-tab>
  </van-tabs>
  <mp-cells title="退款" wx:if="{{allSettled}}" >
    <mp-cell>
      <view class="view-row" >
        <view class="left-column" >【总计押金】</view>
        <view class="right-column" >{{order.rentProperties.totalPaidGuarantyAmountStr}}</view>
        <view class="left-column" >【总计租金】</view>
        <view class="right-column" >{{order.totalRentSummaryAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" >
        <view class="left-column" >【总计超时】</view>
        <view class="right-column" >{{order.totalRentOverTimeAmountStr}}</view>
        <view class="left-column" >【总计赔偿】</view>
        <view class="right-column" >{{order.totalRentRepairationAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" >
        <view class="left-column" >【应退押金】</view>
        <view class="right-column" >{{order.totalRentNeedToRefundAmountStr}}</view>
        <view class="left-column" >【已退金额】</view>
        <view class="right-column" >{{order.refundAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell wx:if="{{order.member && order.member.availableDeposit && order.member.availableDeposit > 0}}"   >
      <view class="view-row" >
        <view class="left-column" >【可用储值】</view>
        <view class="right-column" >{{order.member.availableDepositStr}}</view>
        <view class="left-column" >【支付租金】</view>
        <view class="right-column" >
          <checkbox-group bindchange="setPayWithDeposit"  >
            <checkbox checked="{{payWithDeposit}}" disabled="{{order.depositPaidAmount > 0}}" ></checkbox>
          </checkbox-group>
        </view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" >
        <view class="left-column" >【实际退款】</view>
        <view class="right-column" >
          <input class="input" style="width: 100rpx;text-align: center;" bindinput="setRefundAmount" value="{{order.totalRentUnRefund}}" />
          <view style="height: 20rpx;" ></view>
          <van-button type="danger" size="mini" style="margin-top: 20rpx;" 
            bind:click="refund" disabled="{{refunding || order.closed == 1}}" >退款</van-button>
        </view>
      </view>
    </mp-cell>
  </mp-cells>
  <fui-backdrop show="{{showBackdrop}}" closable >
    <confirm-rental wx:if="{{showBackdrop && backDropType == 'confirm_rental'}}" rentalId="{{currentRentalId}}" 
      bindCloseBackdrop="closeBackdrop" ></confirm-rental>
  </fui-backdrop>
</view>