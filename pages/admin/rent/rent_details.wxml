<view>
  <view class="info-title">订单信息</view>
  <view class="view-row">
    <view class="left-column">【姓名】</view>
    <view class="right-column">{{order.member.title}}</view>
    <view class="left-column">【电话】</view>
    <view class="right-column">
      <van-button size="mini" id="{{order.member.cell}}" bind:click="call" type="info">{{order.member.cell}}
      </van-button>
    </view>
  </view>
  <van-collapse value="{{orderInfoExpand}}" bind:change="expandOrderInfo">
    <van-collapse-item name="1">
      <view slot="title" class="view-row">
        <view class="left-column">【订单号】</view>
        <view class="right-column-whole">{{order.code}}</view>
      </view>
      <view>
        <view class="view-row">
          <view class="left-column">【店铺】</view>
          <view class="right-column">{{order.shop}}</view>
          <view class="left-column">【会员】</view>
          <view class="right-column">{{order.member.following_wechat == 1 ? '会员' : '散客'}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【业务日期】</view>
          <view class="right-column">{{order.bizDateStr}}</view>
          <view class="left-column">【业务时间】</view>
          <view class="right-column">{{order.bizTimeStr}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【关闭日期】</view>
          <view class="right-column">{{order.close_dateDateStr}}</view>
          <view class="left-column">【关闭时间】</view>
          <view class="right-column">{{order.close_dateTimeStr}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【单品数量】</view>
          <view class="right-column">{{order.categoryNum}}</view>
          <view class="left-column">【套餐数量】</view>
          <view class="right-column">{{order.packageNum}}</view>
        </view>
      </view>
    </van-collapse-item>
  </van-collapse>
  <view class="info-title">支付信息</view>
  <van-collapse value="{{payInfoExpand}}" bind:change="expandPayInfo">
    <van-collapse-item name="1">
      <view slot="title" class="view-row">
        <view class="left-column">【支付总金额】</view>
        <view class="right-column">{{order.paidAmountStr}}</view>
        <view class="left-column">【退款总金额】</view>
        <view class="right-column">{{order.refundAmountStr}}</view>
      </view>
      <view>
        <view class="view-row">
          <view class="left-column">【支付总笔数】</view>
          <view class="right-column">{{order.availablePayments.length}}</view>
          <view class="left-column">【退款总笔数】</view>
          <view class="right-column">{{order.availableRefunds.length}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【在押押金】</view>
          <view class="right-column">{{order.unRelieveGuarantyStr}}</view>
          <view class="left-column">【解押押金】</view>
          <view class="right-column">{{order.rentProperties.relieveGuarantyAmountStr}}</view>
        </view>
        <view class="divider"></view>
        <balance wx:if="{{showBalance}}" orderId="{{order.id}}"></balance>
      </view>
    </van-collapse-item>
  </van-collapse>
  <view class="info-title">租赁信息</view>
  <van-collapse value="{{expandRentals}}" bind:change="expandRental">
    <van-collapse-item wx:for="{{order.rentals}}" wx:for-item="rental" wx:for-index="rentalIndex" name="{{rental.id}}">
      <view slot="title" class="view-row">
        <view class="left-column">{{rental.package_id == null? '【套餐】':'【单品】'}}</view>
        <view class="right-column-whole">{{rental.name}}</view>
      </view>
      <view>
        <view class="view-row">
          <view class="left-column">【起租日期】</view>
          <view class="right-column">{{rental.realStartDateStr}}</view>
          <view class="left-column">【起租时间】</view>
          <view class="right-column">——</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【退租日期】</view>
          <view class="right-column">{{rental.realEndDateStr}}</view>
          <view class="left-column">【退租日期】</view>
          <view class="right-column">——</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【租金】</view>
          <view class="right-column">{{rental.totalRentalAmountStr}}</view>
          <view class="left-column">【减免】</view>
          <view class="right-column">{{rental.totalDiscountAmountStr}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【赔偿】</view>
          <view class="right-column">{{rental.totalRepairationAmountStr}}</view>
          <view class="left-column">【超时】</view>
          <view class="right-column">{{rental.totalOvertimeAmountStr}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【招待】</view>
          <view class="right-column">{{rental.entertain == true ? '是' : '否'}}</view>
          <view class="left-column">【小计】</view>
          <view class="right-column">{{rental.totalSummaryStr}}</view>
        </view>
        <view class="divider"></view>
        <view class="view-row">
          <view class="left-column">【备注】</view>
          <view class="right-column" style="width: 75%;">
            <input class="input" disabled="{{rental.moddingMemo!=true}}" style="width: 450rpx;" id="{{rentalIndex}}"
              value="{{rental.memo}}" bindinput="setMemo"></input>
          </view>
        </view>
        <view class="view-row" style="justify-content: center;padding-top: 20rpx;padding-bottom: 20rpx;">
          <block wx:if="{{rental.moddingMemo==true}}">
            <van-button type="warning" size="small" id="{{rentalIndex}}" bind:click="modMemoCancel">取消</van-button>
            <van-button type="danger" size="small" id="{{rentalIndex}}" bind:click="modMemoConfirm"
              style="margin-left: 30rpx;">确认</van-button>
          </block>
          <van-button wx:else type="warning" size="small" id="{{rentalIndex}}" bind:click="modMemo">修改备注</van-button>
        </view>
        <view class="divider"></view>
        <view class="view-row"
          style="padding-left: var(--sub-padding); padding-right: var(--sub-padding);height:auto; align-items: center; ">
          <van-collapse value="{{acrtiveRentalDetails}}" bind:change="expandRentalDetail">
            <van-collapse-item name="{{rental.id}}">
              <view slot="title" class="view-row sub-view-row info-title" style="font-size: 10pt;">
                租金明细
              </view>
              <view>
                <view class="view-row sub-view-row" style="background-color: var(--rental-detail-background-color);">
                  <view class="rent-detail-cell">日期</view>
                  <view class="rent-detail-cell">租金</view>
                  <view class="rent-detail-cell">减免</view>
                  <view class="rent-detail-cell">小计</view>
                  <view class="rent-detail-cell" style="width: 75rpx;">免除</view>
                </view>
                <checkbox-group id="{{rentalIndex}}" bindchange="checkRentalValid">
                  <view class="view-row sub-view-row" wx:for="{{rental.details}}"
                    style="background-color: var(--rental-detail-background-color);">
                    <view class="rent-detail-cell">
                      <block wx:if="{{item.id != 0}}">
                        {{item.rental_dateDateStr}}
                      </block>
                      <input class="input" style="font-size:8pt" wx:else bindtap="showCalendar"
                        value="{{item.rental_dateDateStr}}" id="{{rentalIndex}}_{{index}}" />
                    </view>
                    <view class="rent-detail-cell">
                      <input class="input" style="width: 100rpx;" value="{{item.amount}}"
                        bindinput="setRentalDetailAmount" disabled="{{rental.moddingRentalDetail != true}}"
                        id="{{rentalIndex}}_{{index}}" />
                    </view>
                    <view class="rent-detail-cell">
                      <input class="input" style="width: 100rpx;" value="{{item.othersDiscountAmount}}"
                        id="{{rentalIndex}}_{{index}}" bindinput="setRentalDetailDiscount"
                        disabled="{{rental.moddingRentalDetail != true}}" />
                    </view>
                    <view class="rent-detail-cell">{{item.summaryStr}}</view>
                    <view class="rent-detail-cell" style="width: 75rpx;">
                      <checkbox value="{{index}}" checked="{{item.valid == 0}}"
                        disabled="{{rental.moddingRentalDetail != true}}"></checkbox>
                    </view>
                  </view>
                </checkbox-group>
                <view class="view-row sub-view-row" style="margin-top: 20rpx; justify-content: center;">
                  <block wx:if="{{rental.moddingRentalDetail}}">
                    <van-button type="primary" size="small" id="{{rentalIndex}}" bind:click="addModRenrtalDetail"> 添 加
                    </van-button>
                    <van-button type="warning" size="small" style="margin-left: 50rpx;"
                      bind:click="cancelModRenrtalDetail" id="{{rentalIndex}}"> 取 消 </van-button>
                    <van-button type="danger" size="small" style="margin-left: 50rpx;"
                      bind:click="confirmModRenrtalDetail" id="{{rentalIndex}}"> 确 认 </van-button>
                  </block>
                  <van-button wx:else id="{{rentalIndex}}" type="primary" size="small" bind:click="setModRentalDetail">
                    修 改 </van-button>
                </view>
              </view>
            </van-collapse-item>
          </van-collapse>
        </view>

        <view class="divider"></view>
        <view class="view-row"
          style="padding-left: var(--sub-padding); padding-right: var(--sub-padding);height:auto; align-items: center; ">
          <van-collapse value="{{acrtiveRentalItems}}" bind:change="expandRentalItem">
            <van-collapse-item name="{{rental.id}}">
              <view slot="title" class="view-row sub-view-row info-title" style="font-size: 10pt;">
                租赁物明细
              </view>
              <view wx:for="{{rental.rentItems}}" wx:for-index="itemIndex" wx:if="{{item.next_id == null}}">
                <view class="view-row sub-view-row">
                  <view class="left-column">【名称】{{item.prev_id!=null?'(更)':''}}</view>
                  <view class="right-column-whole">{{item.name}}</view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column">【编码】</view>
                  <view class="right-column-whole">
                    {{item.noNeed == true ? '--' : (item.noCode == true? '无编码' : item.code)}}
                  </view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column">【分类】</view>
                  <view class="right-column-whole" style="width: 550rpx;">
                    {{item.noNeed == true ? '' : item.category.name}}
                  </view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column">【发放日期】</view>
                  <view class="right-column">{{item.noNeed == true ? '--' : item.pickDateStr}}</view>
                  <view class="left-column">【发放时间】</view>
                  <view class="right-column">{{item.noNeed == true ? '--' : item.pickTimeStr}}</view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column">【归还日期】</view>
                  <view class="right-column">{{item.noNeed == true ? '--' : item.returnDateStr}}</view>
                  <view class="left-column">【归还时间】</view>
                  <view class="right-column">{{item.noNeed == true ? '--' : item.returnTimeStr}}</view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column">【发放人】</view>
                  <view class="right-column" style="font-size: 8pt;">
                    {{item.noNeed == true ? '' : (item.pickStaff? item.pickStaff.name: '--')}}
                  </view>
                  <view class="left-column">【接收人】</view>
                  <view class="right-column" style="font-size: 8pt;">
                    {{item.noNeed == true ? '' : (item.returnStaff? item.returnStaff.name: '--')}}
                  </view>
                </view>
                <view class="view-row sub-view-row">
                  <view class="left-column" style="width: 180rpx;">【状态】</view>
                  <view class="right-column" style="width: 150rpx;">
                    {{item.noNeed == true ? '不需要'  : item.status}}
                  </view>
                  <view class="left-column" style="width: 110rpx;">【赔偿】</view>
                  <view class="view-row right-column" style="width: 240rpx;">
                    <input class="input" id="{{item.id}}" bindblur="setRepairAmount"
                      placeholder="{{item.totalRepairationAmount}}" disabled="{{item.setRepairing != true}}"
                      type="number" style="text-align: center;width:50rpx" />
                    <van-button wx:if="{{item.setRepairing != true}}" type="danger" size="mini" id="{{item.id}}"
                      bind:click="setRepair" style="min-width:50rpx">赔偿</van-button>
                    <block wx:else>
                      <van-button type="warning" size="mini" id="{{item.id}}" bind:click="setRepairCancel"
                        style="min-width: 50rpx;">取消</van-button>
                      <van-button type="danger" size="mini" id="{{item.id}}" bind:click="setRepairConfirm"
                        style="min-width: 50rpx;margin-left: 10rpx;">确认</van-button>
                    </block>
                  </view>
                </view>
                <view class="view-row">
                  <view class="left-column">【备注】</view>
                  <view class="right-column-whole" style="width: 500rpx;">
                    <input value="{{item.memo}}" class="input" id="{{rentalIndex}}_{{itemIndex}}"
                      bindinput="setItemMemo" disabled="{{item.moddingMemo!=true}}" />
                  </view>
                </view>
                <view wx:if="{{item.prev_id != null}}" class="sub-view-row"
                  style="padding-left: 20rpx;padding-right:20rpx;">

                  <van-collapse value="{{showChanges}}" bind:change="expandRentalItemChange">
                    <van-collapse-item name="{{rentalIndex}}_{{itemIndex}}">
                      <view class="sub-view-row" slot="title"
                        style="width:calc(var(--total-width) - 8 * var(--sub-padding))">
                        更换记录
                      </view>
                      <view class="sub-view-row" 
                        style="width:calc(var(--total-width) - 8 * var(--sub-padding))" >
                        <block wx:for="{{item.changesLog}}" wx:for-item="change" >
                        <view class="view-row sub-view-row"  >
                          <view class="left-column" >【编码】</view>
                          <view class="right-column-whole" >{{change.code}}</view>
                        </view>
                        <view class="view-row sub-view-row"  >
                          <view class="left-column" >【名称】</view>
                          <view class="right-column-whole" >{{change.name}}</view>
                        </view>
                        <view class="view-row sub-view-row"  >
                          <view class="left-column" >【更换日期】</view>
                          <view class="right-column" >{{change.changeDateStr}}</view>
                          <view class="left-column" >【更换时间】</view>
                          <view class="right-column" >{{change.changeTimeStr}}</view>
                        </view>
                      </block>
                      </view>
                    </van-collapse-item>
                  </van-collapse>
                </view>
                <view class="view-row" style="justify-content: center;margin-top:20rpx">
                  <van-button type="primary" size="small" wx:if="{{item.status == '已发放' }}" id="{{item.id}}"
                    bind:click="setReturn">归还</van-button>
                  <van-button type="primary" size="small" wx:if="{{item.status == '已归还' }}" id="{{item.id}}"
                    bind:click="setUnReturn" disabled="{{order.refundAmount > 0}}">设置未归还</van-button>
                  <van-button type="primary" size="small" id="{{item.id}}" bind:click="setPick"
                    wx:if="{{item.status == '已暂存' || item.status == '未发放' }}">发放</van-button>
                  <van-button type="warning" size="small" style="margin-left: 20rpx;" id="{{item.id}}"
                    wx:if="{{item.status=='已发放'}}" bind:click="setStore">暂存</van-button>
                  <van-button type="danger" size="small" style="margin-left: 20rpx;" id="{{item.id}}"
                    wx:if="{{item.status=='已发放'}}" bind:click="gotoChange">更换</van-button>
                  <block wx:if="{{item.moddingMemo==true}}">
                    <van-button type="warning" size="small" id="{{rentalIndex}}_{{itemIndex}}"
                      bind:click="modItemMemoCancel" style="margin-left:20rpx">取消</van-button>
                    <van-button type="danger" size="small" id="{{rentalIndex}}_{{itemIndex}}"
                      bind:click="modItemMemoConfirm" style="margin-left: 20rpx;">确认</van-button>
                  </block>
                  <van-button wx:else type="warning" size="small" id="{{rentalIndex}}_{{itemIndex}}"
                    bind:click="modItemMemo" style="margin-left:20rpx">修改备注</van-button>
                </view>
              </view>
            </van-collapse-item>
          </van-collapse>
        </view>
      </view>
    </van-collapse-item>
  </van-collapse>
  <block wx:if="{{order.appendingRentals && order.appendingRentals.length > 0}}" >
    <view class="info-title">待添加的租赁商品</view>
    <block wx:for="{{order.appendingRentals}}" wx:for-item="appendingRental" wx:for-index="rentalIndex" >
      <view  class="view-row">
        <view class="left-column">{{appendingRental.package_id == null? '【套餐】':'【单品】'}}</view>
        <view class="right-column-whole">{{appendingRental.name}}</view>
      </view>
      <van-collapse>
        <van-collapse-item>
          <view slot="title" class="view-row sub-view-row" >
            <view class="left-column">【押金】</view>
            <view class="right-column" >
              <input class="input" style="width: 100rpx" />
            </view>
            <view class="left-column">【租金】</view>
            <view class="right-column" >
              <input class="input" style="width: 100rpx" />
            </view>
          </view>
        </van-collapse-item>
      </van-collapse>
    </block>
  </block>
  
</view>













<view style="height:1000rpx"></view>
<view>
  <mp-cells title="订单信息">
    <mp-cell ext-class="my-cell">
      <view class="view-row">
        <view class="left-column">【订单号】</view>
        <view class="right-column">{{order.code}}</view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell">
      <view class="view-row">
        <view class="left-column">【店铺】</view>
        <view class="right-column">{{order.shop}}</view>
        <view class="left-column">【会员】</view>
        <view class="right-column">{{order.member.following_wechat == 1 ? '会员' : '散客'}}</view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell">
      <view class="view-row" style="height: 24rpx;align-items: center;">
        <view class="view-row left-column" style="height: 24rpx;align-items: center;">【姓名】</view>
        <view class="view-row right-column" style="height: 24rpx;align-items: center;">{{order.member.title}}</view>
        <view class="view-row left-column" style="height: 24rpx;align-items: center;">【电话】</view>
        <view class="view-row right-column" style="height: 24rpx;align-items: center;">
          <van-button size="small" id="{{order.member.cell}}" bind:click="call" type="info">{{order.member.cell}}
          </van-button>
        </view>
      </view>
    </mp-cell>
    <mp-cell ext-class="my-cell">
      <view class="view-row">
        <view class="left-column">【业务日期】</view>
        <view class="right-column">{{order.bizDateStr}}</view>
        <view class="left-column">【业务时间】</view>
        <view class="right-column">{{order.bizTimeStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【关闭日期】</view>
        <view class="right-column">{{order.close_dateDateStr}}</view>
        <view class="left-column">【关闭时间】</view>
        <view class="right-column">{{order.close_dateTimeStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【单品数量】</view>
        <view class="right-column">{{order.categoryNum}}</view>
        <view class="left-column">【套餐数量】</view>
        <view class="right-column">{{order.packageNum}}</view>
      </view>
    </mp-cell>
  </mp-cells>
  <mp-cells title="支付信息">
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【支付总笔数】</view>
        <view class="right-column" style="width: 150rpx;">{{order.availablePayments.length}}</view>
        <view class="left-column" style="width: 200rpx;">【支付总金额】</view>
        <view class="right-column" style="width: 150rpx;">{{order.paidAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【退款总笔数】</view>
        <view class="right-column" style="width: 150rpx;">{{order.availableRefunds.length}}</view>
        <view class="left-column" style="width: 200rpx;">【退款总金额】</view>
        <view class="right-column" style="width: 150rpx;">{{order.refundAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 200rpx;">【在押押金】</view>
        <view class="right-column" style="width: 150rpx;">{{order.unRelieveGuarantyStr}}</view>
        <view class="left-column" style="width: 200rpx;">【解押押金】</view>
        <view class="right-column" style="width: 150rpx;">{{order.rentProperties.relieveGuarantyAmountStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" style="justify-content: center;">
        <van-button type="info" size="small" bind:click="showBalance"> 收 支 明 细 </van-button>
      </view>
    </mp-cell>
  </mp-cells>
  <van-tabs active="{{ activeTabIndex }}" bind:change="onTabChange">
    <van-tab title="按租赁商品">
      <mp-cells wx:for="{{order.rentals}}" title="{{item.titleName}}">
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【起租日期】</view>
            <view class="right-column">{{item.realStartDateStr}}</view>
            <view class="left-column">【退租日期】</view>
            <view class="right-column">{{item.realEndDateStr}}</view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【押金】</view>
            <view class="right-column">{{item.guarantyAmountStr}}</view>
            <view class="left-column">【状态】</view>
            <view class="right-column">
              {{item.settled == 1 ?   ((item.realStartDate == null && item.realEndDate == null)? '已取消' :  '已结算' ) : '在租'}}
            </view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【租金】</view>
            <view class="right-column">{{item.totalRentalAmountStr}}</view>
