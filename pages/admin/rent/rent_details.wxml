<view>
  <mp-cells title="订单信息">
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【订单号】</view>
        <view class="right-column">{{order.code}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【店铺】</view>
        <view class="right-column">{{order.shop}}</view>
        <view class="left-column">【会员】</view>
        <view class="right-column">{{order.member.following_wechat == 1 ? '会员' : '散客'}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【姓名】</view>
        <view class="right-column">{{order.member.title}}</view>
        <view class="left-column">【电话】</view>
        <view class="right-column">{{order.member.cell}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【业务日期】</view>
        <view class="right-column">{{order.bizDateStr}}</view>
        <view class="left-column">【业务时间】</view>
        <view class="right-column">{{order.bizTimeStr}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【单品数量】</view>
        <view class="right-column">{{order.categoryNum}}</view>
        <view class="left-column">【套餐数量】</view>
        <view class="right-column">{{order.packageNum}}</view>
      </view>
    </mp-cell>
  </mp-cells>
  <van-tabs active="{{ activeTabIndex }}" bind:change="onTabChange">
    <van-tab title="按租赁商品">
      <mp-cells wx:for="{{order.rentals}}" title="{{item.titleName}}" wx:key="{{rental}}">
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【起租日期】</view>
            <view class="right-column"></view>
            <view class="left-column">【退租日期】</view>
            <view class="right-column"></view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【押金】</view>
            <view class="right-column"></view>
            <view class="left-column">【状态】</view>
            <view class="right-column"></view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【租金】</view>
            <view class="right-column"></view>
            <view class="left-column">【减免】</view>
            <view class="right-column"></view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【赔偿】</view>
            <view class="right-column"></view>
            <view class="left-column">【超时】</view>
            <view class="right-column"></view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row">
            <view class="left-column">【小计】</view>
            <view class="right-column"></view>
          </view>
        </mp-cell>
        <mp-cell>
          <view class="view-row" style="justify-content: center;">
            <van-button type="info" size="small">租金明细</van-button>
            <van-button id="{{item.id}}" type="primary" size="small" style="margin-left: 50rpx;" bind:click="showRentItem">租赁物明细</van-button>
          </view>
        </mp-cell>
      </mp-cells>
    </van-tab>
    <van-tab title="按租赁物">
      <mp-cells wx:for="{{order.rentals}}" wx:for-item="rental" title="{{rental.titleName}}" 
      wx:if="{{currentRentalId == null || (currentRentalId == rental.id) }}">
       <block wx:for="{{rental.rentItems}}" >
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【名称】</view>
              <view class="right-column" style="width: 500rpx;">{{item.name}}</view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row">
              <view class="left-column">【编码】</view>
              <view class="right-column">{{item.code}}</view>
              <view class="left-column">【分类】</view>
              <view class="right-column"></view>
            </view>
          </mp-cell>
          <mp-cell>
            <view class="view-row" style="justify-content: center;" >
              <van-button type="primary" size="small"  >归还</van-button>
              <van-button type="warning" size="small" style="margin-left: 50rpx;" >暂存</van-button>
              <van-button type="danger" size="small" style="margin-left: 50rpx;" >赔偿</van-button>
              <van-button type="info" size="small" style="margin-left: 50rpx;" >发还记录</van-button>
            </view>
          </mp-cell>
        </block>
      </mp-cells>
      <view class="view-row" style="justify-content: center;" wx:if="{{currentRentalId != null}}">
        <van-button type="info" bind:click="showAllRentItem"> 查 看 全 部 </van-button>
      </view>
    </van-tab>
  </van-tabs>
</view>