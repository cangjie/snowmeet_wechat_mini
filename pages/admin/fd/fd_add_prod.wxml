<view style="margin-top: 50rpx;">
  <view class="view-row" >
    <view class="left-column" >分类：</view>
    <view class="right-column" style="text-align: center;" >
      <picker  range="{{categories}}" range-key="name" class="input" bindchange="selectCategory" >
        <picker-view >
          <view style="margin-left: auto; margin-right: auto;">{{selectedCategory ? selectedCategory.name : '请选择…'}}</view>
        </picker-view>
      </picker>
    </view>
  </view>
  <view class="view-row" >
    <view class="left-column" >名称：</view>
    <view class="right-column" >
      <input class="input" style="width: 450rpx;" bindinput="input" id="name" />
    </view>
  </view>
  <view class="view-row" >
    <view class="left-column" >简介：</view>
    <view class="right-column" >
      <textarea class="input" style="width: 450rpx; height: 200rpx;" bindinput="input" id="content" ></textarea>
    </view>
  </view>
  <view class="view-row" >
    <view class="left-column" >价格：</view>
    <view class="right-column" ><input class="input" style="width: 100rpx;" id="price" type="number" /></view>
  </view>
  <view class="view-row" >
    <view class="left-column" >库存：</view>
    <view class="right-column" style="display: flex; flex-direction: row;width: 75%;" >
      <input class="input" style="width: 100rpx;" id="stock_num" type="number" />
      <switch style="margin-left: 50rpx;">无需填写</switch>
    </view>
  </view>
  <view class="view-row" style="height: 64rpx;align-items: center;" >
    <view class="left-column"   >上架：</view>
    <view class="right-column" ><switch checked="{{true}}" ></switch></view>
  </view>
  <block wx:if="{{selectedCategory}}" >
    <view class="view-row" wx:for="{{selectedCategory.availableProperties}}" style="align-items: center;" >
      <view class="left-column" >{{item.property_name}}：</view>
      <view class="right-column" style="width: 75%; display: flex; align-items: center;" >
        <radio-group wx:if="{{item.multi_selected == 0}}" style="display: flex; align-items: center;" >
          <radio wx:for="{{item.availableOptions}}" wx:for-item="option" wx:key="{{option.id}}" 
          style="margin-right: 20rpx;margin-top: 20rpx;" >
            {{option.option_value}}
          </radio>
        </radio-group>
      </view>
    </view>
  </block>
  <view class="view-row" style="align-items: center;" >
    <view class="left-column" >图片：</view>
    <view class="right-column" style="display: flex; align-items: center;flex-direction: column;"  >
      <fui-button btnSize="mini" style="margin-left: 50rpx;" size="35rpx" 
      text=" 上 传 " background="#2EA6D0" bind:click="uploadImage"  ></fui-button>
      
    </view>
  </view>
  <view class="view-row" style="align-items: center;" >
    <view class="left-column" ></view>
    <view class="right-column"   >
      <image mode="heightFix" wx:if="{{productImageUrl}}" style="height: 300rpx;" src="{{productImageUrl}}" ></image>
    </view>
  </view>

  <view style="margin-top: 50rpx;display: flex;width: 750rpx;justify-content: center;">
    <fui-button btnSize="medium" style="margin-left: 50rpx;" size="35rpx" 
      text=" 添 加 " background="#2EA6D0" bind:click="add"  ></fui-button>
  </view>
  <view style="height:100rpx" ></view>
</view>