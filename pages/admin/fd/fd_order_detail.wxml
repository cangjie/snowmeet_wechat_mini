  </fui-card>
  <view style="height: 50rpx;"></view>
  <!--有历史记录的需要历史按钮，需哟修改按钮-->
  <fui-card full>
    <view class="view-row">
      <view>
        【订单备注】
      </view>
      <view>
        <input class="input" id="orderMemo" bindinput="inputMemo" disabled="{{!editingOrderMemo}}" style="width: 500rpx;" placeholder="{{order.memo}}" value="{{editingOrderMemo? null : order.memo}}" />
      </view>
    </view>
    <view class="view-row" wx:if="{{editingOrderMemo}}">
      <view style="width: 187rpx;"></view>
      <view class="view-row" style="width: 188rpx;justify-content: center;">
        <fui-button id="orderMemo" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 确 认 " background="#00AA00" bind:click="confirmMemo"></fui-button>
      </view>
      <view class="view-row" style="width: 188rpx;justify-content: center;">
        <fui-button id="orderMemo" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 取 消 " background="#DD0000" bind:click="cancelMemo"></fui-button>
      </view>
      <view style="width: 187rpx;"></view>
    </view>
    <view class="view-row" wx:else>
      <view style="width: 187rpx;"></view>
      <view class="view-row" style="width: 188rpx;justify-content: center;">
        <fui-button id="orderMemo" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 修 改 " color="#000000" background="#C0C0C0" bind:click="edit"></fui-button>
      </view>
      <view class="view-row" style="width: 188rpx;justify-content: center;">
        <fui-button wx:if="{{orderMemoLog && orderMemoLog.length > 1}}" id="orderMemo" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 历 史 " color="#000000" background="#C0C0C0" bind:click="showLogs"></fui-button>
      </view>
      <view style="width: 187rpx;"></view>
    </view>
  </fui-card>
  <view style="height: 50rpx;"></view>
  <fui-card full>
    <fui-row>
      <fui-col span="7">
        <view>【总计】</view>
