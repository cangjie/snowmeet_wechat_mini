  <view style="height: 50rpx;"></view>
  <fui-card full>
    <view>【订单明细】</view>
    <view style="height: 50rpx;"></view>
    <fui-row>
      <fui-col span="12">
        <view class="view-detail">名称</view>
      </fui-col>
      <fui-col span="3">
