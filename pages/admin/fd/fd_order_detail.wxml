  <view style="height: 50rpx;"></view>
  <fui-card full>
    <view>【订单明细】</view>
    <view style="height: 50rpx;"></view>
    <fui-row>
      <fui-col span="12">
        <view class="view-detail">名称</view>
      </fui-col>
      <fui-col span="3">
        <view class="view-detail">单价</view>
      </fui-col>
      <fui-col span="3">
        <view class="view-detail">数量</view>
      </fui-col>
      <fui-col span="3">
        <view class="view-detail">减免</view>
      </fui-col>
      <fui-col span="3">
        <view class="view-detail">小计</view>
      </fui-col>
    </fui-row>


    <block wx:for="{{order.fdOrders}}">
      <view style="height: 50rpx;"></view>
      <fui-row>
        <fui-col span="12">
          <view class="view-detail">{{item.product_name}}</view>
        </fui-col>
        <fui-col span="3">
          <view class="view-detail" style="text-align: right;">{{item.unit_priceStr}}</view>
        </fui-col>
        <fui-col span="2">
          <view class="view-detail">{{item.count}}</view>
        </fui-col>
        <fui-col span="3">
          <view class="view-detail" style="text-align: right;margin-left:10rpx">{{item.discountAmountStr}}</view>
        </fui-col>
        <fui-col span="3">
          <view class="view-detail" style="text-align: right;margin-left: 10rpx;">{{item.summaryStr}}</view>
        </fui-col>
      </fui-row>
      <view class="view-row">
        <view>【备注】</view>
        <view>
          <input id="{{index}}" class="input"  bindinput="inputMemo" disabled="{{!item.editing}}" style="width: 560rpx;" placeholder="{{item.memo}}" value="{{item.editing? null : item.memo}}" />
        </view>
      </view>
      <view class="view-row" wx:if="{{item.editing}}">
        <view style="width: 187rpx;"></view>
        <view class="view-row" style="width: 188rpx;justify-content: center;">
          <fui-button id="{{index}}" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 确 认 " background="#00AA00" bind:click="confirmMemo"></fui-button>
        </view>
        <view class="view-row" style="width: 188rpx;justify-content: center;">
          <fui-button id="{{index}}" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 取 消 " background="#DD0000" bind:click="cancelMemo"></fui-button>
        </view>
        <view style="width: 187rpx;"></view>
      </view>
      <view class="view-row" wx:else>
        <view style="width: 187rpx;"></view>
        <view class="view-row" style="width: 188rpx;justify-content: center;">
          <fui-button id="{{index}}" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 修 改 " color="#000000" background="#C0C0C0" bind:click="edit"></fui-button>
        </view>
        <view class="view-row" style="width: 188rpx;justify-content: center;">
          <fui-button wx:if="{{item.logs.length > 1}}" id="{{index}}" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 历 史 " color="#000000" background="#C0C0C0" bind:click="showLogs" ></fui-button>
        </view>
        <view style="width: 187rpx;"></view>
      </view>
    </block>



