<view>
  <view style="height: 50rpx;"></view>
  <fui-card full>
    <fui-row>
      <fui-col span="6">
        <view>【订单号】</view>
      </fui-col>
      <fui-col span="18">
        <view>{{order.code}}</view>
      </fui-col>
    </fui-row>
    <fui-row>
      <fui-col span="5">
        <view>【日期】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.dateStr}}</view>
      </fui-col>
      <fui-col span="5">
        <view>【时间】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.timeStr}}</view>
      </fui-col>
    </fui-row>
    <fui-row>
      <fui-col span="5">
        <view>【类型】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.is_testStr}}</view>
      </fui-col>
      <fui-col span="5">
        <view>【招待】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.haveEnterainStr}}</view>
      </fui-col>
    </fui-row>
    <fui-row>
      <fui-col span="5">
        <view>【套餐】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.is_packageStr}}</view>
      </fui-col>
      <fui-col span="5">
        <view>【挂账】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.creditInfo}}</view>
      </fui-col>
    </fui-row>
    <fui-row>
      <fui-col span="5">
        <view>【减免】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.haveDiscountStr}}</view>
      </fui-col>
      <fui-col span="5">
        <view>【状态】</view>
      </fui-col>
      <fui-col span="7">
        <view>{{order.orderStatus}}</view>
      </fui-col>
    </fui-row>
    <fui-row wx:if="{{orderStatusLog.length > 1}}">
      <fui-col span="7" offset="17">
        <fui-button id="orderStatus" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 历 史 " color="#000000" background="#C0C0C0" bind:click="showLogs"></fui-button>
      </fui-col>
    </fui-row>
  </fui-card>
