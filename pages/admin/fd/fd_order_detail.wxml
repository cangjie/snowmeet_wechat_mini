        </fui-col>
        <fui-col span="11">
          <view style="margin-left: 50rpx;">
            <fui-button id="discount" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 补 收 " color="#000000" background="#C0C0C0" bind:click="edit"></fui-button>
          </view>
        </fui-col>
      </fui-row>
    </block>

