  <fui-bottom-popup show="{{showMemo}}" bindclose="closeMemo">
    <view class="fui-scroll__wrap">
      <view class="fui-title fui-title__pb">{{memoTitle}}</view>
      <scroll-view scroll-y class="fui-scroll__view">
        <block wx:if="{{showOrderStatusLog}}">
          <fui-row>
            <fui-col span="6">
              <view style="text-align: center;">日期</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">时间</view>
            </fui-col>
            <fui-col span="6">
              <view style="text-align: center;">状态</view>
            </fui-col>
            <fui-col span="7">
              <view style="text-align: center;">店员</view>
            </fui-col>
          </fui-row>
          <fui-row wx:for="{{orderStatusLog}}">
            <fui-col span="6">
              <view style="text-align: center;">{{item.dateStr}}</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">{{item.timeStr}}</view>
            </fui-col>
            <fui-col span="6">
              <view style="text-align: center;">{{item.current_value}}</view>
            </fui-col>
            <fui-col span="7">
              <view style="text-align: center;">{{item.staffName}}</view>
            </fui-col>
          </fui-row>
        </block>
        <block wx:if="{{showOrderMemoLog}}">
          <fui-row>
            <fui-col span="6">
              <view style="text-align: center;">日期</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">时间</view>
            </fui-col>
            <fui-col span="13">
              <view style="text-align: center;">历史备注</view>
            </fui-col>
          </fui-row>
          <fui-row wx:for="{{orderMemoLog}}">
            <fui-col span="6">
              <view style="text-align: center;">{{item.dateStr}}</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">{{item.timeStr}}</view>
            </fui-col>
            <fui-col span="13">
              <view style="text-align: center;">{{item.current_value}}</view>
            </fui-col>
          </fui-row>
        </block>
        <block wx:if="{{showFdMemoLog}}">
          <fui-row>
            <fui-col span="6">
              <view style="text-align: center;">日期</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">时间</view>
            </fui-col>
            <fui-col span="13">
              <view style="text-align: center;">历史备注</view>
            </fui-col>
          </fui-row>
          <fui-row wx:for="{{fdMemoLog}}">
            <fui-col span="6">
              <view style="text-align: center;">{{item.dateStr}}</view>
            </fui-col>
            <fui-col span="5">
              <view style="text-align: center;">{{item.timeStr}}</view>
            </fui-col>
            <fui-col span="13">
              <view style="text-align: center;">{{item.current_value}}</view>
            </fui-col>
          </fui-row>
        </block>
        <!--fui-list-cell wx:for="{{itemList}}" wx:key="index">item{{index+1}}</fui-list-cell-->
      </scroll-view>
      <view class="fui-icon__close" bindtap="closeMemo">
        <fui-icon name="close" size="{{48}}"></fui-icon>
      </view>
    </view>
  </fui-bottom-popup>
</view>