          </fui-col>
          <fui-col span="11"></fui-col>
        </fui-row>
        <fui-row>
          <fui-col span="7">
            <view>【已付金额】</view>
          </fui-col>
          <fui-col span="4">
            <view style="text-align: right;">{{order.paidAmountStr}}</view>
          </fui-col>
          <fui-col span="11"></fui-col>
        </fui-row>
        <fui-row>
          <fui-col span="7">
            <view>【还需支付】</view>
          </fui-col>
          <fui-col span="4">
            <view style="text-align: right;">{{order.unpaidAmountStr}}</view>
          </fui-col>
          <fui-col span="11"></fui-col>
        </fui-row>
        <!--fui-row>
          <fui-col span="7">
            <view>【本次支付】</view>
          </fui-col>
          <fui-col span="4">
            <view style="text-align: right;">{{order.currentPaidAmountStr}}</view>
