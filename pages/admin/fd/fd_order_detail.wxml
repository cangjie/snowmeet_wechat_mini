          </view>
          <view>
            <fui-button wx:if="{{order.paidAmount > 0}}" id="paidHistory" margin="5rpx" width="100rpx" height="50rpx" size="29" text=" 历 史 " color="#000000" background="#C0C0C0" bind:click="showBalance"></fui-button>
          </view>
        </view>


      </fui-col>
