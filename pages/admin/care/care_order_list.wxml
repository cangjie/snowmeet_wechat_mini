  </fui-card>
  <view class="view-row" style="justify-content: center;width: 750rpx;">
    <van-button type="info" size="normal" style="margin-top: 20rpx;" bind:click="query" disabled="{{querying}}"> 查 询 </van-button>
  </view>
  <view class="view-row" style="margin-top: 50rpx;" >
    订单数：{{orders.length}} 总金额：{{totalAmountStr}}
  </view>
  <block wx:for="{{orders}}">
    <fui-card style="margin-top: 50rpx;" title="{{item.code}}" 
    tag="{{item.careProperties.orderStatus }}" tagSize="10rpx" full>
      <view class="fui-card__content view-row" style="margin-bottom: 20rpx;">
        <view style="width: 90rpx; margin-left: 0rpx;margin-top: 10rpx;border-right: #0C0C0C solid 2rpx;" id="{{index}}" bindtap="gotoDetail">
          <view wx:if="{{item.is_test == 1}}">【测】</view>
          <view wx:if="{{item.haveEntertain==true}}">【招】</view>
          <view wx:if="{{item.is_package == 0}}">【单】</view>
          <view wx:if="{{item.haveOnCredit}}">【挂】</view>
          <view wx:if="{{item.haveDiscount}}">【减】</view>
          <view wx:if="{{item.haveWarranty==true}}">【质】</view>
          <view>{{item.memberShip}}</view>
        </view>
        <view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【日期】</view>
            <view class="right-column" style="width: 150rpx;">{{item.dateStr}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column" >【时间】</view>
            <view class="right-column" style="width: 120rpx;">{{item.timeStr}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【顾客称呼】</view>
            <view class="right-column" style="width: 270rpx;margin-right: 0rpx;">{{item.calledName}}</view>

          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【手机】</view>
            <view class="right-column">{{item.customerCell}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【支付方式】</view>
            <view class="right-column">{{ item.payMethod==null? '--' : item.payMethod }}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【支付金额】</view>
            <view class="right-column" style="width: 100rpx;">{{item.paidAmountStr}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【退款金额】</view>
            <view class="right-column">{{item.refundAmountStr}}</view>
          </view>
          <view class="view-row" >
            <view class="left-column">【总计收款】</view>
            <view class="right-column" style="width: 100rpx;">{{item.totalEarnAmountStr}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【装备数量】</view>
            <view class="right-column">{{ item.cares.length}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【项目】</view>
            <view class="right-column">{{ item.careProperties.services }}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【开单人】</view>
            <view class="right-column">{{item.staff.name}}</view>
          </view>
          <view class="view-row" id="{{index}}" bindtap="gotoDetail">
            <view class="left-column">【备注】</view>
            <view class="right-column">{{item.memo}}</view>
          </view>
          <view class="view-row" wx:if="{{item.careProperties.orderStatus != '临时订单'}}" >
            <view class="left-column"></view>
            <view class="right-column">
              <van-button size="small" type="primary" id="{{index}}" bind:click="gotoDetail"> 查 看 详 细 </van-button>
            </view>
          </view>
        </view>
        <view style="width: 240rpx;">
          <view wx:for="{{item.cares}}" wx:for-item="care" >
            <image mode="heightFix" style="width: 220rpx;" wx:if="{{care.careImages.length > 0}}" src="https://snowmeet.wanlonghuaxue.com{{care.careImages[0].image.thumbUrl}}" ></image>
          </view>
        </view>
      </view>
    </fui-card>
    <view style="height: 20rpx;"></view>
  </block>
</view>