<view wx:if="{{staff && staff.title_level >= 100}}" style="margin-top: 50rpx;" >
  <fui-card full>
    <fui-row>
      <fui-col span="5">
        <view class="fui-left-column">【店铺】</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column">
          <shop-selector wx:if="{{(keyword != null && keyword != '') || (cell != null && cell != '')}}" defaultShop=""  
            bindShopSelected="shopSelected"   ></shop-selector>
          <shop-selector wx:else  bindShopSelected="shopSelected"   ></shop-selector>
        </view>
      </fui-col>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【日期】</view>
      </fui-col>
      <fui-col span="18">
        <view class="fui-right-column view-row">
          <picker id="start" mode="date" class="input" style="margin-right:20rpx;" 
            bindchange="setDate"  disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}">
            <picker-view>{{startDate}}</picker-view>
          </picker>
          -
          <picker id="end" mode="date" class="input" style="margin-left:20rpx;" 
            disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" bindchange="setDate">
            <picker-view>{{endDate}}</picker-view>
          </picker>
        </view>
      </fui-col>
    </fui-row>
  </fui-card>
  <view style="height: 20rpx;"></view>
  <fui-card full>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【测试】</view>
      </fui-col>
      <radio-group id="isTest" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="false" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >营业</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="{{true}}" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >测试</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="null" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >全部</radio>
        </fui-col>

      </radio-group>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【招待】</view>
      </fui-col>
      <radio-group id="isEntertain" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="false" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >正常</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="true" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >招待</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="null" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >全部</radio>
        </fui-col>
      </radio-group>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【减免】</view>
      </fui-col>
      <radio-group id="haveDiscount" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="null" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >全部</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="true" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >包含</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="false" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >不含</radio>
        </fui-col>
      </radio-group>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【质保】</view>
      </fui-col>
      <radio-group id="haveWarranty" bindchange="setQueryOptions">
        <fui-col span="6">
          <radio checked="{{true}}" value="null" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >全部</radio>
        </fui-col>
        <fui-col span="6">
          <radio value="true" disabled="{{(keyword != null && keyword != '') ||(cell != null && cell != '') || querying}}" >包含</radio>
        </fui-col>
        <fui-col span="7">
          <radio value="false" disabled="{{(keyword != null && keyword != '') || (cell != null && cell != '') || querying}}" >不含</radio>
        </fui-col>
      </radio-group>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【手机】</view>
      </fui-col>
      <fui-col span="6">
        <input class="input" bindinput="setCell" style="text-align: center;"  type="number" />
      </fui-col>
    </fui-row>
    <fui-row style="margin-top: 20rpx;">
      <fui-col span="5">
        <view class="fui-left-column">【备注】</view>
      </fui-col>
      <fui-col span="6">
        <input class="input" bindinput="setMemo" style="text-align: center;"   />
      </fui-col>
    </fui-row>
    <!--radio-group id="status" bindchange="setQueryOptions">
      <fui-row style="margin-top: 20rpx;">
        <fui-col span="5">
          <view class="fui-left-column">【状态】</view>
        </fui-col>
        <fui-col span="6">
          <radio checked="{{true}}" value="支付成功">支付成功</radio>
        </fui-col>
