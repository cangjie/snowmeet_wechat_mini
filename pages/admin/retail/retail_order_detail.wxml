<view>
  <mp-cells title="顾客下单信息">
    <mp-cell ext-class="thin-cell" >
      <view class="view-row">
        <view class="left-column" style="width: 140rpx;">【姓名】</view>
        <view class="right-column" style="width: 200rpx;">
          <input class="input" disabled="{{!moddingContactInfo}}" id="contact_name" bindinput="inputContactInfo" value="{{order.contact_name}}" style="width: 150rpx;text-align: center;" />
        </view>
        <view class="left-column" style="width: 140rpx;">【状态】</view>
        <view class="right-column">{{order.memberShip}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column" style="width: 140rpx;">【性别】</view>
        <view class="right-column view-row" style="width: 200rpx;">
          <radio-group id="contact_gender" bindchange="inputContactInfo">
            <radio disabled="{{!moddingContactInfo}}" checked="{{order.contact_gender == '男'}}" value="男">男</radio>
            <radio disabled="{{!moddingContactInfo}}" checked="{{order.contact_gender == '女'}}" value="女">女</radio>
          </radio-group>
        </view>
        <view class="left-column" style="width: 140rpx;">【手机号】</view>
        <view class="right-column">
          <input class="input" type="number" disabled="{{!moddingContactInfo}}" id="contact_num" value="{{order.contact_num}}" style="width: 160rpx;" bindinput="inputContactInfo" />
        </view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" style="justify-content: center;">
        <block wx:if="{{moddingContactInfo}}">
          <van-button type="warning" size="small" bind:click="cancelModContactInfo" style="margin-right: 50rpx;"> 取 消 </van-button>
          <van-button type="danger" size="small" bind:click="confirmModContactInfo" style="margin-left: 50rpx;"> 确 认 </van-button>
        </block>
        <van-button wx:else type="primary" size="small" bind:click="modContactInfo"> 修 改 </van-button>
      </view>
    </mp-cell>
  </mp-cells>
  <mp-cells title="订单信息">
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【订单号】</view>
        <view class="right-column">{{order.code}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【七色米单号】</view>
        <view class="right-column">
          <block wx:if="{{order.retails[0].mi7_code || moddingOrderInfo}}">
            <input class="input" style="width: 260rpx;text-align: center;" id="mi7_code" value="{{order.retails[0].mi7_code}}" bindinput="inputOrderInfo" disabled="{{!moddingOrderInfo}}" />
          </block>
          <block wx:else>
            紧急开单
          </block>
        </view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" style="height: {{moddingOrderInfo?'200':'50'}}rpx;" >
        <view class="left-column">【订单类型】</view>
        <view class="right-column view-row" style="width: 580rpx;height:100rpx" wx:if="{{moddingOrderInfo}}">
          <radio-group id="retail_type" bindchange="inputOrderInfo" >
            <radio checked="{{order.retails[0].retail_type == '零售'}}" value="零售">零售</radio>
            <radio style="margin-left: 10rpx;" checked="{{order.retails[0].retail_type == '期货预定'}}" 
            value="期货预定">期货预定</radio>
            <radio style="margin-left: 10rpx;margin-top:10rpx" 
            checked="{{order.retails[0].retail_type == '养护卡类'}}" value="养护卡类">养护卡类</radio>
            <radio style="margin-top:10rpx" value="租赁卡类"
            checked="{{order.retails[0].retail_type == '租赁卡类'}}" >租赁卡类</radio>
            <radio style="margin-left: 10rpx;margin-top:10rpx" value="二手装备"
            checked="{{order.retails[0].retail_type == '二手装备'}}" >二手装备</radio>
            <radio style="margin-left: 0rpx;margin-top:10rpx" value="雪鞋定型"
            checked="{{order.retails[0].retail_type == '雪鞋定型'}}" >雪鞋定型</radio>
          </radio-group>
        </view>
        <view class="right-column" wx:else>{{order.retails[0].retail_type==null?'未填':order.retails[0].retail_type}}</view>

      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【招待】</view>
        <view class="right-column">{{order.haveEntertain == 1? '是' : '否'}}</view>
      </view>
    </mp-cell>
    <mp-cell wx:if="{{order.paying_amount}}">
      <view class="view-row">
        <view class="left-column">【支付金额】</view>
        <view class="right-column">
          <block wx:if="{{order.haveEntertain == 1}}">
            ¥0.00
          </block>
          <block wx:else>
            <input class="input" style="width: 100rpx;text-align: center;" type="digit" bindinput="inputOrderInfo" value="{{order.paying_amount}}" disabled="{{!moddingOrderInfo}}" id="paying_amount" />
          </block>
        </view>
      </view>
    </mp-cell>
    <mp-cell wx:else>
      <view class="view-row">
        <view class="left-column">【订单金额】</view>
        <view class="right-column">
          <block wx:if="{{order.haveEntertain == 1}}">
            ¥0.00
          </block>
          <block wx:else>
            {{order.totalAmountStr}}
          </block>
        </view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【备注】</view>
        <view class="right-column" style="height:200rpx;">
          <textarea style="width: 400rpx;height: 200rpx;" class="input" disabled="{{!moddingOrderInfo}}" id="memo" bindinput="inputOrderInfo" value="{{order.retails[0].memo}}"></textarea>
        </view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row">
        <view class="left-column">【订单状态】</view>
        <view class="right-column">{{order.orderStatus}}</view>
      </view>
    </mp-cell>
    <mp-cell>
      <view class="view-row" >
        <van-uploader file-list="{{order.retailImages}}" bind:after-read="afterRead" capture="['album', 'camera']" bind:delete="delImage"  bind:delete="delImage" show-upload="{{moddingOrderInfo == true}}" deletable="{{moddingOrderInfo == true}}" />
      </view>
      
    </mp-cell>
    <mp-cell>
      <view class="view-row" style="justify-content: center;">
        <block wx:if="{{moddingOrderInfo}}">
          <van-button type="warning" size="small" bind:click="cancelModOrderInfo" style="margin-right: 50rpx;"> 取 消 </van-button>
          <van-button type="danger" size="small" bind:click="confirmModOrderInfo" style="margin-left: 50rpx;"> 确 认 </van-button>
        </block>
        <van-button wx:else type="primary" size="small" bind:click="modOrderInfo"> 修 改 </van-button>
      </view>
    </mp-cell>
  </mp-cells>
  <mp-cells title="支付" wx:if="{{order.orderStatus == '待生成' || order.orderStatus == '待支付'}}">
    <mp-cell>
      <payment orderId="{{order.id}}" bindOrderStatusChanged="orderStatusChanged" bindOrderPaidResult="dealPaidResult"></payment>
    </mp-cell>
  </mp-cells>
</view>