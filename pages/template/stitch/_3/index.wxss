@import "../tokens.wxss";

.page-root {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 56px; /* bottom nav */
}

/* Topbar */
.topbar {
  height: 56px;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: sticky;
  top: 0;
  z-index: 50;
}
.topbar-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
.topbar-title { color: var(--primary); font-weight: 700; font-size: 18px; }

/* Category tabs */
.cat-tabs {
  background: #ffffff;
  border-bottom: 1px solid var(--outline-variant);
  white-space: nowrap;
}
.cat-tabs-inner {
  padding: 12px 16px;
  display: inline-flex;
  gap: 12px;
}
.cat-chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 999px;
  background: var(--surface-container-low);
  color: var(--on-surface-variant);
  border: 1px solid var(--outline-variant);
  font-size: 12px;
  font-weight: 600;
}
.cat-chip--active {
  background: var(--primary-container);
  color: var(--on-primary-container);
  border-color: var(--primary-container);
}

/* Package scroll */
.pkg-scroll {
  flex: 1;
  height: 0;
}
.pkg-list {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* Package card */
.pkg-card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  padding: 12px;
}
.pkg-card--active {
  border-color: var(--primary);
  border-width: 2px;
  padding: 11px;
}
.pkg-head { display: flex; gap: 12px; align-items: flex-start; }
.pkg-checkbox {
  width: 22px;
  height: 22px;
  border-radius: 6px;
  border: 1.5px solid var(--outline);
  background: #ffffff;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}
.pkg-checkbox--on {
  background: var(--primary);
  border-color: var(--primary);
}
.pkg-body { flex: 1; min-width: 0; }
.pkg-title { font-size: 18px; font-weight: 700; color: var(--on-surface); margin-bottom: 4px; }
.pkg-desc { font-size: 13px; color: var(--on-surface-variant); margin-bottom: 12px; line-height: 1.5; }

.price-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  background: var(--surface-container-low);
  padding: 8px;
  border-radius: 8px;
  margin-bottom: 12px;
}
.price-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.price-cell--bordered { border-left: 1px solid var(--outline-variant); }
.price-label { font-size: 10px; font-weight: 700; color: var(--on-surface-variant); letter-spacing: 0.4px; }
.price-label--member { color: var(--primary); }
.price-value { font-size: 18px; font-weight: 700; color: var(--on-surface); }
.price-value--member { color: var(--primary); }

.stepper-wrap { display: flex; justify-content: flex-end; }
.stepper {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: var(--surface-container-low);
  border: 1px solid var(--outline-variant);
  border-radius: 999px;
  padding: 4px 6px;
}
.stepper-btn {
  width: 32px;
  height: 32px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.stepper-btn--minus { background: #ffffff; border: 1px solid var(--outline-variant); }
.stepper-btn--plus  { background: var(--primary); }
.stepper-value {
  font-size: 14px;
  font-weight: 700;
  color: var(--on-surface);
  min-width: 20px;
  text-align: center;
}

.empty {
  padding: 64px 16px;
  text-align: center;
  color: var(--on-surface-variant);
  font-size: 14px;
}

/* Footer */
.modal-footer {
  background: var(--surface-container-lowest);
  border-top: 1px solid var(--outline-variant);
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.footer-summary { display: flex; flex-direction: column; gap: 4px; }
.footer-line-1 { font-size: 12px; font-weight: 600; color: var(--on-surface-variant); }
.footer-line-2 { display: flex; align-items: baseline; gap: 4px; }
.footer-total-label { font-size: 14px; color: var(--on-surface); }
.footer-total-value { font-size: 28px; font-weight: 800; color: var(--primary); line-height: 1; }
.confirm-btn {
  background: var(--primary);
  color: var(--on-primary);
  height: 48px;
  padding: 0 32px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.confirm-btn::after { border: none; }
.confirm-btn--disabled {
  background: var(--surface-container-high);
  color: var(--on-surface-variant);
}

/* Bottom nav */
.bottomnav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 56px;
  background: #ffffff;
  border-top: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 60;
}
.bottomnav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  color: var(--on-surface-variant);
  font-size: 10px;
  font-weight: 500;
  flex: 1;
}
.bottomnav-item.active { color: var(--primary); }
