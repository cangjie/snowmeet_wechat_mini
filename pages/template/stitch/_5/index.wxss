@import "../tokens.wxss";

.page-root {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 88px; /* room for confirm button */
}

/* Topbar */
.topbar {
  height: 56px;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  position: sticky;
  top: 0;
  z-index: 50;
}
.topbar-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
.topbar-title {
  flex: 1;
  text-align: center;
  color: var(--on-surface);
  font-weight: 600;
  font-size: 18px;
}

.main {
  flex: 1;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  max-width: 480px;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
}

/* Order details card */
.order-card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 8px;
  padding: 16px;
}
.order-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.order-card-title { font-size: 14px; font-weight: 600; color: var(--on-surface); }
.order-card-body {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--outline-variant);
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.kv-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.kv-row--multiline { align-items: flex-start; }
.kv-label { font-size: 13px; color: var(--on-surface-variant); }
.kv-value { font-size: 13px; color: var(--on-surface); font-weight: 500; text-align: right; }
.kv-value-list { display: flex; flex-direction: column; gap: 2px; align-items: flex-end; }
.kv-value-item { font-size: 13px; color: var(--on-surface); }

/* Amount */
.amount {
  text-align: center;
  padding: 12px 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.amount-label { font-size: 13px; color: var(--on-surface-variant); }
.amount-value {
  font-size: 36px;
  font-weight: 800;
  color: var(--primary-container);
  line-height: 1.1;
  letter-spacing: -0.5px;
}
.amount-sub { font-size: 11px; color: var(--on-surface-variant); margin-top: 4px; }

/* QR card */
.qr-card {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 12px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.qr-frame {
  width: 192px;
  height: 192px;
  background: var(--surface-container);
  border-radius: 8px;
  border: 1px solid var(--outline-variant);
  padding: 16px;
  box-sizing: border-box;
  position: relative;
}
.qr-mock {
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  grid-template-rows: repeat(8, 1fr);
  gap: 2px;
  position: relative;
}
.qr-grid { display: contents; }
.qr-cell { background: transparent; border-radius: 1px; }
.qr-cell--on { background: var(--on-surface); }
.qr-corner {
  position: absolute;
  width: 32px;
  height: 32px;
  border: 4px solid var(--on-surface);
  border-radius: 4px;
  background: var(--surface-container-lowest);
}
.qr-corner--tl { top: 0; left: 0; }
.qr-corner--tr { top: 0; right: 0; }
.qr-corner--bl { bottom: 0; left: 0; }

.qr-tip {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--on-surface-variant);
}
.qr-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  justify-content: center;
}
.qr-meta-label { font-size: 11px; font-weight: 700; color: var(--on-surface-variant); letter-spacing: 0.4px; }
.qr-meta-status {
  font-size: 12px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 999px;
}
.qr-meta-status--wait { background: var(--surface-container); color: var(--on-surface-variant); }
.qr-meta-status--ok   { background: #dcfce7; color: #15803d; }

/* Pay list */
.pay-list {
  background: var(--surface-container-lowest);
  border: 1px solid var(--outline-variant);
  border-radius: 8px;
  overflow: hidden;
}
.pay-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid var(--outline-variant);
}
.pay-row:last-child { border-bottom: none; }
.pay-row--active { background: var(--surface-container-low); }
.pay-row-left { display: flex; align-items: center; gap: 12px; }
.pay-icon {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pay-icon--wechat { background: #09b83e; }
.pay-icon--alipay { background: #1677ff; }
.pay-icon--other  { background: var(--secondary); }
.pay-row-text { font-size: 13px; font-weight: 600; color: var(--on-surface); }

.spacer { flex: 1; }

/* Bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #ffffff;
  border-top: 1px solid var(--outline-variant);
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  z-index: 40;
}
.confirm-btn {
  width: 100%;
  height: 48px;
  background: var(--primary-container);
  color: var(--on-primary);
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.confirm-btn::after { border: none; }
