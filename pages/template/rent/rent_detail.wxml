<view>
  <van-collapse value="{{ activeNames }}" bind:change="onCollapseChange">
    <van-collapse-item title="订单基本信息" name="info" value="租赁中">
      <view class="view-row">
        <view class="left-column">【订单号】</view>
        <view class="right-column" style="width: 550rpx;">WT_ZL_251129_00003</view>
      </view>
      <view class="view-row">
        <view class="left-column">【业务日期】</view>
        <view class="right-column right-column-sub">2025-11-29</view>
        <view class="left-column">【业务时间】</view>
        <view class="right-column right-column-sub">2025-11-29</view>
      </view>
      <view class="view-row">
        <view class="left-column">【姓名】</view>
        <view class="right-column right-column-sub" style="width: 170rpx;margin-left: 10rpx;">张先生</view>
        <view class="left-column">【电话】</view>
        <view class="right-column right-column-sub">13501177897</view>
      </view>
      <view class="view-row">
        <view class="left-column">【订单状态】</view>
        <view class="right-column right-column-sub">租赁中</view>
        <view class="left-column">【开单店员】</view>
        <view class="right-column right-column-sub">王五</view>
      </view>
    </van-collapse-item>
    <van-collapse-item title="押金" value="实付押金：¥2000.00" name="guaranty">
      <view class="view-row">
        <view class="left-column">【押金总计】</view>
        <view class="right-column right-column-sub amount">¥2000.00</view>
        <view class="left-column">【追加押金】</view>
        <view class="right-column right-column-sub amount">¥0.00</view>
      </view>
      <view class="view-row">
        <view class="left-column">【押金减免】</view>
        <view class="right-column right-column-sub amount">¥0.00</view>
        <view class="left-column">【实付押金】</view>
        <view class="right-column right-column-sub amount">¥2000.00</view>
      </view>
      <view class="view-row">
        <view class="left-column">【应退押金】</view>
        <view class="right-column right-column-sub amount">¥0.00</view>
        <view class="left-column"></view>
        <view class="right-column right-column-sub amount"></view>
      </view>
      <view class="view-row" style="justify-content: center; margin-top: 20rpx;">
        <van-button plain type="primary"> 查 看 押 金 明 细 </van-button>
      </view>
    </van-collapse-item>
    <van-collapse-item title="租金" value="已确认租金：¥500.00" name="rentals">
      <view class="view-row">
        <view class="left-column">【已确认租金】</view>
        <view class="right-column right-column-sub amount">¥500.00</view>
        <view class="left-column"></view>
        <view class="right-column right-column-sub amount"></view>
      </view>
      <view class="view-row">
        <view class="left-column">【未结算租金】</view>
        <view class="right-column right-column-sub amount">¥500.00</view>
        <view class="left-column">【已结算租金】</view>
        <view class="right-column right-column-sub amount">¥0.00</view>
      </view>
      <view class="view-row" style="justify-content: center; margin-top: 20rpx;">
        <van-button plain type="primary"> 查 看 租 金 明 细 </van-button>
      </view>
    </van-collapse-item>
    <van-collapse-item title="商品及租赁物" value="套餐：1 单品：1 总计：3" name="list">
      <van-tabs active="{{ activeTab }}" bind:change="onTabChange">
        <van-tab title="按商品">
          <rental-list rentals="{{rentals}}" ></rental-list>
        </van-tab>
        <van-tab title="按品类">
          <rent-item-list rentals="{{rentals}}" ></rent-item-list>
        </van-tab>
      </van-tabs>
    </van-collapse-item>

  </van-collapse>
</view>