      <fui-swipe-action wx:for="{{rentals}}" wx:for-item="rental" bind:click="del" id="{{index}}" >
        <view wx:if="{{rental.package_id == null || rental.package_id == undefined}}" class="view-row" >
          <view class="number-label" style="margin-top: 100rpx;" >{{rental.rentItems[0].itemIndex}}. </view>
          <view style="width: 650rpx; background-color: #F0F0F0;"  bindtap="showItem">
            <view class="view-row" >
              <view class="left-column" >类型：</view>
              <view class="right-column right-column1" >单品</view>
              <view class="left-column" ></view>
              <view class="right-column" > </view>
            </view>
            <view class="view-row" >
              <view class="left-column" >押金：</view>
              <view class="right-column right-column1" >¥5000.00</view>
              <view class="left-column" >租金：</view>
              <view class="right-column" >¥100.00起</view>
            </view>
            <view class="view-row"  >
              <view class="left-column" >品类：</view>
              <view class="right-column" style="width: 550rpx;" >手套 > 电加热手套</view>
            </view>
            <view class="view-row" >
              <view class="left-column" >编码：</view>
              <view class="right-column right-column1" >211</view>
              <view class="left-column" >名称：</view>
              <view class="right-column" >铝合金150cm</view>
            </view>
          </view>
        </view>
        <view wx:else >
          套餐
        </view>
      </fui-swipe-action>
