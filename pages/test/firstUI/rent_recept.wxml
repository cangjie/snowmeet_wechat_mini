  </view>
  <view style="height: 50rpx;"></view>
  <fui-card title="新增租赁物" tag="">
	  <view class="fui-card__content">
      <radio-group bindchange="selectType">
        <view class="view-row radio-item"  >
          <radio value="套餐" checked="{{type=='套餐'}}" >套餐</radio> 
          <picker style="margin-left: 50rpx;width: 350rpx;" range="{{packageList}}" range-key="name" 
          class="input" bindchange="selectPackage"  disabled="{{type!='套餐'}}"  >
            <picker-view>{{packageSelectIndex? packageList[packageSelectIndex].name: '请选择'}}</picker-view>
          </picker>  
        </view>
        <view class="view-row radio-item" style="margin-bottom: 20rpx;margin-top:40rpx" >
          <radio value="单品" checked="{{type=='单品'}}" >单品</radio>
          <input class="input" value="{{barcode}}" placeholder="直接输入" bindinput="inputBarcode"
            style="margin-left: 50rpx; width: 200rpx;" disabled="{{type != '单品'}}"  />
          <button style="width:45rpx; height:45rpx; margin-left:20rpx; margin-right: 0rpx;" 
            bindtap="scan" size="mini" class="input" disabled="{{type != '单品' || barCodeInputing}}" >
            <image src="../../../images/scan.jpeg" style="width: 60rpx; height: 45rpx;margin-left: -15px;" />
          </button>
          <button class="input" size="mini" disabled="{{type != '单品' || barCodeInputing}}"
            style="height:55rpx;font-size: 9pt;" >直接新增</button>
          <!--picker style="margin-left: 50rpx;width: 480rpx" class="input" mode="multiSelector" 
          range="{{categoryPickerArr}}" range-key="name" disabled="{{type == '套餐'}}"
          bindcolumnchange="catePickerColChange" bindchange="selectCategoryOk" >
            <picker-view>{{categorySelectIndex == undefined ? '请选择': categorySelectText}}</picker-view>
          </picker-->
          
        </view>
      </radio-group>
    </view>
  </fui-card>
</view>
<fui-backdrop show="{{show}}" closable >
  <rent-recept-package wx:if="{{showPackage}}" bindKeep="close"></rent-recept-package>
  <rent-recept-item wx:if="{{showItem}}" bindKeep="close"></rent-recept-item>
</fui-backdrop>