/* pages/ticket-booking/index.wxss */

/* =====================
   CSS 变量 / 设计 Token
   ===================== */
page {
  --primary: #1A73E8;
  --primary-light: #4285F4;
  --primary-container: #D1E4FF;
  --on-primary: #FFFFFF;
  --surface: #F8F9FF;
  --surface-container-lowest: #FFFFFF;
  --surface-container-low: #F3F3F7;
  --surface-container: #EDEFF3;
  --surface-container-high: #E7E8EC;
  --surface-container-highest: #DFE3EB;
  --on-surface: #1A1C1E;
  --on-surface-variant: #44474E;
  --outline: #74777F;
  --outline-variant: #C4C6D0;
  --error: #BA1A1A;

  background-color: var(--surface);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--on-surface);
}

/* =====================
   页面容器
   ===================== */
.page-container {
  min-height: 100vh;
  background-color: var(--surface);
  position: relative;
}

/* =====================
   顶部导航栏
   ===================== */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44rpx 24rpx 14rpx;
  background-color: var(--surface);
  /* 底部分割线：用渐变色代替 1px border */
  box-shadow: 0 1rpx 0 rgba(116, 119, 127, 0.12);
}

.top-bar-left {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.top-bar-left:active {
  background: rgba(26, 115, 232, 0.08);
}

.icon-back {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
}

.top-bar-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on-surface);
  letter-spacing: -0.5rpx;
}

.top-bar-right {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-more {
  font-size: 36rpx;
  color: var(--on-surface);
  letter-spacing: -2rpx;
}

/* =====================
   主内容滚动区
   ===================== */
.main-content {
  padding-top: 120rpx;
  height: 100vh;
  box-sizing: border-box;
}

/* =====================
   Hero 横幅
   ===================== */
.hero-section {
  position: relative;
  margin: 20rpx 24rpx 0;
  border-radius: 32rpx;
  overflow: hidden;
  height: 260rpx;
  box-shadow:
    0 16rpx 40rpx rgba(26, 115, 232, 0.15),
    0 4rpx 16rpx rgba(0, 0, 0, 0.10);
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(26, 28, 30, 0.85) 0%,
    rgba(26, 28, 30, 0.2) 55%,
    transparent 100%
  );
}

.hero-content {
  position: absolute;
  bottom: 28rpx;
  left: 32rpx;
  right: 32rpx;
}

.premium-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: var(--primary-container);
  color: #001D4A;
  padding: 6rpx 18rpx;
  border-radius: 9999rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 0 20rpx rgba(26, 115, 232, 0.4);
}

.badge-star {
  font-size: 18rpx;
  color: var(--primary);
}

.badge-text {
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.25;
  letter-spacing: -0.5rpx;
}

.hero-subtitle {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 6rpx;
}

/* =====================
   表单区域
   ===================== */
.form-section {
  padding: 24rpx 24rpx 0;
}

/* =====================
   Bento 网格（日期 + 数量）
   ===================== */
.bento-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.bento-card {
  background: var(--surface-container-lowest);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow:
    0 8rpx 28rpx rgba(26, 115, 232, 0.06),
    0 2rpx 6rpx rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.2s;
}

.bento-card:active {
  box-shadow:
    0 4rpx 12rpx rgba(26, 115, 232, 0.06),
    0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.card-label {
  display: block;
  font-size: 18rpx;
  font-weight: 800;
  color: var(--outline);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 14rpx;
}

/* 日期卡片 */
.date-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.date-value {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--on-surface);
  letter-spacing: -1rpx;
}

.date-sub {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
}

.calendar-icon {
  font-size: 40rpx;
  opacity: 0.5;
}

/* 数量卡片 */
.qty-card {
  background: var(--surface-container-low);
}

.qty-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}

.qty-btn:active {
  transform: scale(0.88);
}

.qty-minus {
  background: var(--surface-container-highest);
}

.qty-plus {
  background: var(--primary-container);
  box-shadow: 0 6rpx 18rpx rgba(26, 115, 232, 0.2);
}

.qty-btn-text {
  font-size: 36rpx;
  font-weight: 300;
  color: var(--on-surface);
  line-height: 1;
}

.qty-plus .qty-btn-text {
  color: #001D4A;
}

.qty-plus--disabled {
  background: var(--surface-container-highest) !important;
  box-shadow: none !important;
  opacity: 0.4;
  pointer-events: none;
}

.qty-plus--disabled .qty-btn-text {
  color: var(--outline) !important;
}

.qty-value {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--on-surface);
  letter-spacing: -2rpx;
  min-width: 60rpx;
  text-align: center;
}

/* =====================
   游客信息卡片
   ===================== */
.info-card {
  background: var(--surface-container-lowest);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 8rpx 28rpx rgba(26, 115, 232, 0.06),
    0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.info-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.header-accent {
  width: 5rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 9999rpx;
}

.info-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.field-item {
  position: relative;
}

.field-label {
  display: block;
  font-size: 18rpx;
  font-weight: 800;
  color: var(--outline);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 10rpx;
}

.field-input {
  width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-surface);
  padding: 0;
  border: none;
  background: transparent;
  box-sizing: border-box;
  line-height: 1.4;
}

.field-placeholder {
  color: var(--outline-variant);
  font-weight: 400;
}

.field-underline {
  height: 2rpx;
  background: var(--outline-variant);
  border-radius: 2rpx;
  margin-top: 8rpx;
  opacity: 0.4;
  transition: all 0.25s;
}

.field-underline--active {
  background: var(--primary);
  opacity: 1;
}

/* 电话行 */
.phone-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.phone-input {
  flex: 1;
}

.autofill-btn {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  background: var(--surface-container-high);
  border-radius: 16rpx;
  transition: background 0.2s;
}

.autofill-btn:active {
  background: var(--surface-container-highest);
}

.autofill-text {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--on-surface-variant);
  letter-spacing: 1rpx;
}

/* =====================
   提示信息条
   ===================== */
.info-tip {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  background: rgba(26, 115, 232, 0.05);
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(26, 115, 232, 0.12);
}

.tip-icon {
  font-size: 28rpx;
  color: var(--primary);
  font-style: normal;
  flex-shrink: 0;
  margin-top: -1rpx;
}

.tip-text {
  font-size: 22rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

/* =====================
   底部占位
   ===================== */
.bottom-placeholder {
  height: 160rpx;
}

/* =====================
   底部支付栏（玻璃效果）
   ===================== */
.pay-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(248, 249, 255, 0.88);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: 0 -2rpx 0 rgba(196, 198, 208, 0.3);
}

.price-section {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.price-label {
  font-size: 16rpx;
  font-weight: 800;
  color: var(--outline);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-currency {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.price-value {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--on-surface);
  letter-spacing: -2rpx;
  line-height: 1;
}

.pay-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #1A73E8 0%, #4285F4 100%);
  box-shadow:
    0 12rpx 30rpx rgba(26, 115, 232, 0.28),
    0 4rpx 10rpx rgba(26, 115, 232, 0.18);
  transition: all 0.15s;
}

.pay-btn:active {
  transform: scale(0.97);
  box-shadow:
    0 6rpx 16rpx rgba(26, 115, 232, 0.22),
    0 2rpx 6rpx rgba(26, 115, 232, 0.14);
}

.pay-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.pay-btn-arrow {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 400;
}

/* =====================
   日期选择弹窗
   ===================== */
.date-picker-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(26, 28, 30, 0.5);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.date-picker-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.date-picker-panel {
  width: 100%;
  background: var(--surface-container-lowest);
  border-radius: 48rpx 48rpx 0 0;
  padding: 32rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--outline-variant);
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--on-surface);
}

.picker-close {
  font-size: 36rpx;
  color: var(--outline);
  padding: 8rpx;
}

.picker-view {
  width: 100%;
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 32rpx;
  color: var(--on-surface);
}

.picker-confirm-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #1A73E8 0%, #4285F4 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.picker-confirm-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}
